  "description": "ServiceCycle API Server - ServiceCycle",
  "main": "index.ts",
  "scripts": {
    "start": "node node_modules/tsx/dist/cli.mjs index.ts",
    "dev": "tsx watch index.ts",
    "type-check": "tsc --noEmit",
    "build": "tsc --noEmit",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "node prisma/seed.js",
    "studio": "prisma studio",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "sbom:sync": "node scripts/sbom-sync.js",
    "guide:sync": "node scripts/sync-ai-guide.js",
    "help:sync": "node scripts/sync-help.js",
    "openapi:sync": "node scripts/sync-openapi.js",
    "openapi:build": "node scripts/build-openapi.js",
    "openapi:check": "node scripts/check-openapi-drift.js",
    "update-vendor-notes": "node scripts/update-vendor-notes.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
