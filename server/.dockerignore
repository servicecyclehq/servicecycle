# ServiceCycle server .dockerignore — Sprint 5 (B2)
#
# Applies when building the server image (build context = ./server,
# wired in docker-compose.yml). Paths are relative to ./server; nothing
# outside the server tree is ever in the build context, so we don't
# need to exclude client/, prisma migrations are KEPT (the image needs
# them to run `prisma migrate deploy` at boot).

# ── Secrets — NEVER ship ─────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.*.local
secrets/
credentials.json

# ── Runtime data (bind-mounted at runtime, not baked in) ─────────────────────
uploads/
backups/

# ── Build artefacts and deps (regenerated by the deps stage) ─────────────────
node_modules/
dist/
build/
coverage/
.cache/
.vite/
.prisma/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Stray scratch files spotted in the working tree ──────────────────────────
# These were never tracked in git (see git status), but must be excluded
# defensively in case a future contributor adds them and forgets.
_check_user.js
_reset_pw.js
p.$disconnect())
check.js
err.log
out.log
srv.log

# ── Docs and IDE ─────────────────────────────────────────────────────────────
NEXT_SESSION.md
*.md
.git
.gitignore
.vscode
.idea
*.swp
.DS_Store
Thumbs.db

# ── Test files ───────────────────────────────────────────────────────────────
*.test.js
*.spec.js
__tests__/
test/
tests/

# ── Don't recursively bundle Docker artefacts ────────────────────────────────
Dockerfile
Dockerfile.*
.dockerignore
