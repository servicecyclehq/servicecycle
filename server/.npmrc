# 2026-07-08 overnight security hardening (SOC2 AI-code-security research,
# docs/security/AI_CODE_SECURITY_RESEARCH_2026-07-07.md).
#
# save-exact: lockfile pins exact versions (no ^/~ ranges) for anything
# newly installed here, closing the gap where a compromised/malicious
# transitive dependency could slip in via a semver-range bump between
# audits.
#
# ignore-scripts: DELIBERATELY NOT enabled yet, despite being on the
# original hardening list -- verified tonight that `sharp` (image
# processing, used for nameplate photos etc.) ships its own required
# "install" script (`node install/check.js || npm run build`, see
# node_modules/sharp/package.json) that fetches the correct prebuilt
# native libvips binary for the platform. `ignore-scripts=true` is
# all-or-nothing across every dependency -- it would silently break
# sharp on the next fresh `npm ci` (the Dockerfile's build step, line 45)
# with no compensating step anywhere else in the build. Confirmed Prisma
# is NOT at risk (Dockerfile already runs `npx prisma generate` as an
# explicit step, line 50 -- doesn't depend on @prisma/client's postinstall
# either way), but sharp has no such explicit fallback yet.
# To actually enable ignore-scripts safely: add an explicit
# `RUN node node_modules/sharp/install/check.js` (or equivalent) step to
# the Dockerfile right after `npm ci`, verify a real image build+deploy
# still processes a nameplate photo correctly, THEN flip this on. Didn't
# want to guess at that and risk breaking image processing in prod
# unsupervised overnight -- flagging as a scoped follow-up instead.
save-exact=true
