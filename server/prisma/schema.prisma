// Quote Request: why the customer is asking for a quote.
// PENDING BROTHER VALIDATION â€” these 5 options are our best guess for the
// electrical-maintenance service context; validate with real customer discovery.
enum QuoteDriver {
  down_now // Asset is down right now â€” triggers EMERGENCY mode
  suspected_failing // Intermittent issues / early warning signs
  failed_inspection // Failed NETA/NFPA inspection or audit finding
  planned_replacement // Scheduled capital replacement project
  budgetary // Just gathering numbers for future budget cycle
}

// Quote Request: customer's target timeline to proceed.
// PENDING BROTHER VALIDATION â€” adjust wording to match how your reps quote these.
enum QuoteTimeline {
  immediately // ASAP (pairs with down_now driver)
  within_1_week // Need action within 7 days
  within_30_days // Need to schedule within the month
  next_budget_cycle // Planning, no immediate urgency
}

// Quote Request: current status in the service rep workflow.
enum QuoteRequestStatus {
  requested // Customer submitted; rep has not yet responded
  quoted // Rep sent a quote (quotedAt + quoteNotes populated)
  accepted // Customer accepted the quote
  declined // Customer declined â€” reason captured (audit/liability trail)
  draft // Saved by the customer but NOT yet sent (no rep email / partner event)
}

enum AccountStatus {
  active
  expiring
  lapsed
  read_only
  inactive
}

enum PlanType {
  saas
  licensed
}

enum PlanTier {
  small
  mid
  enterprise
}

enum UserRole {
  admin
  manager
  viewer
  consultant // Maintenance Vendor account manager â€” receives alerts in tandem
  oem_admin // OEM service org fleet manager â€” cross-account read-only view
  group_admin // Enterprise group (HoldCo) admin â€” cross-OpCo read-only roll-up over accounts sharing an enterpriseGroupId
  super_admin // Platform super-admin â€” can manage PartnerOrganizations and bootstrap OEM users
  field_tech // Field-labor / subcontractor login â€” assigned-jobs-only. NO pricing, NO full customer list. Default-deny everywhere except the assignment-scoped /api/field surface; sees only WorkOrders where assignedUserId = their id.
}

// Equipment taxonomy. Expanded 2026-06-07 from the buyer-priority analysis
// (most common / most expensive to repair / most infrastructure-critical):
// the backbone distribution gear, protection/switching devices, cabling,
// power quality, and safety systems that NFPA 70B / NETA MTS / NFPA 110/99
// programs actually track. Postgres enums are append-only here â€” never
// remove or rename a value without a data migration plan.
enum EquipmentType {
  TRANSFORMER_LIQUID
  TRANSFORMER_DRY
  SWITCHGEAR
  SWITCHBOARD
  PANELBOARD
  BUSWAY
  GENERATOR
  MOTOR
  MCC
  VFD
  UPS_BATTERY
  BATTERY_SYSTEM // stationary strings + chargers (switchgear control, telecom) â€” IEEE 450/1188
  CIRCUIT_BREAKER
  FUSE_GEAR // fusible switches/fuse cabinets â€” ratings verification + spares
  DISCONNECT_SWITCH // air/oil/vacuum switches, load-break, pad-mounted
  TRANSFER_SWITCH // ATS â€” life-safety critical, NFPA 110/99 monthly transfer tests
  PROTECTION_RELAY // SEL/GE class â€” calibration vs coordination study
  GROUND_FAULT_PROTECTION // NEC 230.95 performance testing
  SURGE_ARRESTER
  CABLE_LV // â‰¤600V feeders â€” IR testing history per run
  CABLE_MV_HV // medium/high voltage â€” VLF/partial discharge class
  CABLE_TRAY // structural supports â€” corrosion/loading inspection
  GROUNDING_SYSTEM // fall-of-potential / point-to-point per IEEE 81
  EMERGENCY_LIGHTING // egress/battery units â€” NFPA 101 monthly/annual tests
  ARC_FLASH_PANEL
  FIRE_PUMP_CONTROLLER
}

// NFPA 70B:2023 condition of maintenance ratings.
// C1 = good (interval Ã—2.5, max 60 months) Â· C2 = fair (base interval)
// C3 = poor (interval Ã—0.25, max 12 months)
enum ConditionRating {
  C1
  C2
  C3
}

enum WorkOrderStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETE
  CANCELLED
}

// Shared by NETA decal (work order) and per-measurement pass/fail.
// GREEN = pass Â· YELLOW = pass with deficiencies noted Â· RED = fail
enum ResultRating {
  GREEN
  YELLOW
  RED
}

// NETA MTS deficiency classification.
enum DeficiencySeverity {
  IMMEDIATE
  RECOMMENDED
  ADVISORY
}

// ANSI/NETA ETT certification levels.
enum NetaCertLevel {
  LEVEL_I
  LEVEL_II
  LEVEL_III
  LEVEL_IV
}

enum CommunicationType {
  call
  email_thread
  meeting
  note
}

// Alert taxonomy. Lead-time tiers (180/120/90/60/30/7) are expressed via
// Alert.leadDays on maintenance_due rows; overdue/escalation rows carry
// null leadDays and use daysOverdue semantics in the engine.
enum AlertType {
  maintenance_due
  overdue
  escalation
  regulatory_breach
}

enum AlertStatus {
  pending
  sent
  acknowledged
  escalated
  cancelled
}

// Phase 4 #8: continuous condition-monitoring reading status. OK = within
// thresholds; WARN = crossed a warn band; CRIT = crossed a critical band. A
// CRIT reading is the NFPA 70B:2023 "unaddressed continuous-monitoring
// notification" that drives the asset to Condition 2 until acknowledged.
enum TelemetryStatus {
  OK
  WARN
  CRIT
}

enum IngestionStatus {
  processing
  review_pending
  approved
  imported
  failed
}

enum PartnerEventType {
  IMMEDIATE_DEFICIENCY
  INSPECTION_COMPLETED
  QUOTE_REQUEST_CREATED
  TASK_OVERDUE
  PROPOSAL_DISCUSSION_REQUESTED
}

enum RetentionTier {
  STANDARD // 7 years
  HEALTHCARE // 10 years
  UTILITY // permanent (never archived)
  CUSTOM
}

// Document type classification â€” surfaces documents grouped by purpose on the
// asset detail page. oem_manual + wiring_diagram cover vendor docs; loto_pdf
// covers a scanned/printed LOTO procedure (vs. the structured LotoProc model);
// the rest cover the usual facilities-compliance paper trail.
enum DocType {
  oem_manual // Manufacturer operation + maintenance manual
  wiring_diagram // One-lines, schematics, as-built drawings
  loto_pdf // Scanned/printed LOTO procedure (PDF backup)
  test_report // NETA / contractor test report
  inspection_report // Insurance or regulatory inspection report
  commissioning_report // Initial energisation / SAT report
  warranty // Warranty certificate or service contract
  other
}

// Lockout/Tagout procedure lifecycle.
enum LotoStatus {
  draft // Being authored; not yet in use
  active // Current approved procedure for this asset
  archived // Superseded by a newer revision
}

// OSHA 29 CFR 1910.147 energy source categories that require isolation.
enum EnergyType {
  electrical
  pneumatic
  hydraulic
  mechanical
  thermal
  chemical
  gravity
}

// â”€â”€â”€ Models â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Account {
  id                       String        @id @default(uuid())
  companyName              String
  status                   AccountStatus @default(active)
  planType                 PlanType
  planTier                 PlanTier?
  stripeCustomerId         String?
  // Stripe seam â€” populated by a future Checkout flow + webhook handler.
  // Null on self-hosted licensed instances (planType=licensed), which
  // bypass tier enforcement entirely.
  stripeSubscriptionId     String?
  stripeSubscriptionStatus String? // active | past_due | canceled | trialing | unpaid | incomplete
  stripeCurrentPeriodEnd   DateTime? // grace logic + renewal alert anchor
  licenseDate              DateTime?
  supportExpiresAt         DateTime?
  // Debounced last-activity timestamp. Only meaningful in DEMO_MODE where it
  // drives the per-visitor sandbox prune (5-day inactivity TTL). Updated by
  // middleware/auth.js at most once per hour per account.
  lastActiveAt             DateTime?
  // Per-account AI toggle (maintenance recommendation + NFPA compliance
  // summary). Default OFF on self-host so operators opt in explicitly; the
  // per-session consent modal gates behind it. Demo seed flips this to true.
  aiBriefEnabled           Boolean       @default(false)
  // When true, admin-role users on this account are required to have TOTP
  // enrolled. Default false to preserve current behaviour on existing accounts.
  mfaRequiredForAdmins     Boolean       @default(false)
  // Per-account service representative contact. Used to route quote requests
  // and display the "CALL NOW" number in EMERGENCY mode. Editable in Settings.
  serviceRepName           String?
  serviceRepEmail          String?
  serviceRepPhone          String?
  // OEM partner linkage -- links this customer account to a PartnerOrganization
  // for fleet-level visibility by oem_admin users.
  partnerOrgId             String?
  // Phase 4 #9 enterprise group (HoldCo) linkage -- a customer-side parent over
  // its operating companies (OpCos). DISTINCT from partnerOrgId (the OEM channel):
  // an OpCo can be in an OEM fleet AND a HoldCo at once. group_admin users on a
  // member account get a cross-OpCo read-only roll-up across accounts sharing
  // this id. Nullable -- standalone accounts have none.
  enterpriseGroupId        String?
  // Partner flywheel: assigned service rep + fallback rep routing
  assignedRepId            String? // FK â†’ User (primary rep)
  fallbackRepId            String? // FK â†’ User (fallback rep, nullable)
  // Data retention tier for PartnerEventLog archival
  retentionTier            RetentionTier @default(STANDARD)
  retentionCustomYears     Int? // used when retentionTier=CUSTOM
  // Per-tenant total headcount â€” drives cost-per-employee KPI tiles.
  // Nullable so existing accounts continue to work.
  fteCount                 Int?
  // Import webhook â€” single per-account endpoint for assets.imported events.
  // URL and secret stored encrypted (same AES-256-GCM path as webhookEndpoints).
  // Secret is generated server-side and shown once; never re-surfaced.
  importWebhookUrl         String? // HTTPS URL; stored encrypted
  importWebhookSecret      String? // 32-byte hex; stored encrypted; HMAC-SHA256 signing key
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  users                  User[]
  contractors            Contractor[]
  sites                  Site[]
  assets                 Asset[]
  maintenanceSchedules   MaintenanceSchedule[]
  taskDefinitions        MaintenanceTaskDefinition[]
  workOrders             WorkOrder[]
  testMeasurements       TestMeasurement[]
  deficiencies           Deficiency[]
  systemStudies          SystemStudy[]
  labSamples             LabSample[]
  auditVisits            AuditVisit[]
  auditRecommendations   AuditRecommendation[]
  blackoutWindows        BlackoutWindow[]
  standardRevisionAlerts StandardRevisionAlert[]
  documents              Document[]
  communications         Communication[]
  alerts                 Alert[]
  ingestionSessions      IngestionSession[]
  invites                UserInvite[]
  settings               AccountSetting[]
  consultantAccesses     ConsultantAccess[]
  backupLogs             BackupLog[]
  customFieldDefinitions CustomFieldDefinition[]
  apiKeys                ApiKey[]
  apiIdempotencyKeys     ApiIdempotencyKey[]
  webhookEndpoints       WebhookEndpoint[]
  outboundWebhookDlq     OutboundWebhookDLQ[]
  webhookDeliveries      WebhookDelivery[]
  activityLogs           ActivityLog[]
  notificationLogs       NotificationLog[]
  complianceSnapshots    ComplianceSnapshot[]
  quoteRequests          QuoteRequest[]
  lotoProcs              LotoProc[]
  lotoEnergySources      LotoEnergySource[]
  lotoSteps              LotoStep[]
  disasterEvents         DisasterEvent[]
  assetTemplates         AssetTemplate[]
  telemetryChannels      TelemetryChannel[]
  telemetryReadings      TelemetryReading[]
  telemetryNotifications TelemetryNotification[]

  partnerOrg       PartnerOrganization? @relation(fields: [partnerOrgId], references: [id], onDelete: SetNull)
  enterpriseGroup  EnterpriseGroup?     @relation(fields: [enterpriseGroupId], references: [id], onDelete: SetNull)
  assignedRep      User?                @relation("AssignedRep", fields: [assignedRepId], references: [id], onDelete: SetNull)
  fallbackRep      User?                @relation("FallbackRep", fields: [fallbackRepId], references: [id], onDelete: SetNull)
  partnerInvites   PartnerInvite[]
  partnerEventLogs PartnerEventLog[]
  incidentLogs     IncidentLog[]
  shareLinks       ShareLink[]
  ingestJobs       IngestJob[]
  // Enterprise SSO / SCIM (feature/sso-polis)
  ssoConnections   SsoConnection[]
  ssoDomains       SsoDomain[]
  scimDirectories  ScimDirectory[]
  ssoRoleMappings  SsoRoleMapping[]
  ssoLoginStates   SsoLoginState[]
  ssoHandoffs      SsoHandoff[]

  @@index([enterpriseGroupId])
  @@map("accounts")
}

// â”€â”€â”€ Async ingest jobs (#2) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Moves facility-scale document ingest off the HTTP request: an upload is stored
// and enqueued, an in-process worker (lib/ingestWorker) claims it with
// SELECT ... FOR UPDATE SKIP LOCKED, runs the SHARED buffer->preview builder
// (lib/testReportPreview) across all pages, and stores the preview `result` for
// the client to poll + review-then-commit. Underpins #34 backfill and #6 email-in.
enum IngestJobStatus {
  queued
  processing
  done
  failed
  needs_review // parsed, but the confidence gate parked it for human approval
  rejected // a reviewer discarded it; no assets were written
}

model IngestJob {
  id              String          @id @default(uuid())
  accountId       String
  createdById     String? // uploader (nullable for system/email-in)
  kind            String          @default("test_report") // test_report | backfill | email_in
  status          IngestJobStatus @default(queued)
  fileKey         String // storage key of the persisted upload
  fileName        String?
  // #6 email-in: auto-commit the parsed report straight to asset cards (no human
  // in the loop) and the site that auto-created assets are placed on.
  autoCommit      Boolean         @default(false)
  siteId          String?
  // #14: when an oem_admin enqueues into a fleet customer account, the worker
  // builds the preview against this target (validated at enqueue time).
  targetAccountId String?
  progress        Int             @default(0) // 0-100
  phase           String? // human-readable stage for the polling UI
  result          Json? // the preview payload (same shape as POST /preview data)
  error           String?
  attempts        Int             @default(0)
  // Confidence-gate review (auto-commit safety). The worker scores the parsed
  // preview: high-confidence identity + readings auto-commit; anything below the
  // bar parks as needs_review for human approval. `gate` stores the decision
  // (band + reasons) so the review queue renders without recomputing.
  gate            Json?
  reviewedById    String? // who approved/rejected (null = auto-committed, no human)
  reviewedAt      DateTime?
  // #6 email-in post-parse acknowledgement: the sender to notify once the whole
  // inbound message is gated, and the batch id correlating the jobs from one
  // email so the ack aggregates (and fires exactly once via ackSentAt claim).
  notifyEmail     String?
  batchId         String?
  ackSentAt       DateTime?
  startedAt       DateTime? // claim timestamp (drives stale-claim recovery)
  finishedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([accountId, createdAt])
  @@index([accountId, status]) // review-queue lookups (needs_review per account)
  @@index([batchId])
  @@map("ingest_jobs")
}

// â”€â”€â”€ OEM Partner Organizations â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Represents an OEM service organization (Eaton, Schneider, ABB, etc.).
// Customer accounts are linked via partnerOrgId.  Users with role oem_admin
// on any account in the same partner org get cross-account fleet visibility.
model PartnerOrganization {
  id                 String   @id @default(uuid())
  name               String
  logoUrl            String?
  primaryColor       String? // hex, e.g. "#0057b8"
  website            String?
  webhookUrl         String?
  webhookSecret      String? // 32-byte hex; HMAC-SHA256 signing key
  digestIntervalDays Int      @default(1) // 1â€“7 days; OEM configurable
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  accounts         Account[]
  partnerInvites   PartnerInvite[]
  partnerEventLogs PartnerEventLog[]

  @@map("partner_organizations")
}

model User {
  id                            String    @id @default(uuid())
  accountId                     String
  name                          String
  email                         String    @unique
  passwordHash                  String
  role                          UserRole
  isActive                      Boolean   @default(true)
  // L2 (2026-06-09 audit): monotonic token epoch for instant access-token
  // revocation. Access tokens embed the current value as the `ep` claim; the
  // auth middleware rejects any token whose `ep` differs from this column.
  // Incremented on password change, password reset, and admin password reset
  // so those events kill every outstanding access token immediately rather
  // than waiting out the (short) token TTL.
  tokenEpoch                    Int       @default(0)
  passwordResetToken            String?
  passwordResetExpiresAt        DateTime?
  lastLogin                     DateTime?
  twoFactorSecret               String? // AES-256-GCM encrypted TOTP secret
  twoFactorEnabled              Boolean   @default(false)
  twoFactorBackupCodes          String? // JSON array of SHA-256-hashed one-time backup codes
  twoFactorLastUsedStep         BigInt? // TOTP replay prevention â€” step index of last successful verify
  featureFlags                  Json? // admin-set feature booleans
  hiddenFeatures                Json? // user-set: features they've personally hidden
  // When true, viewer-role user only sees assets at sites they are assigned
  // to (scoping rewire lands with the routes adaptation; column preserved
  // from the inherited scope-restriction pattern).
  assetScopeRestricted          Boolean   @default(false)
  // Persist the OnboardingWizard step on the user row so the wizard resumes
  // across devices.
  onboardingStep                Int       @default(0)
  // Terms acceptance audit trail â€” populated at registration. Nullable so
  // legacy/seed users continue to work without a backfill ritual.
  acceptedTermsAt               DateTime?
  acceptedTermsVersion          String? // e.g. "tos-2026-05-04, privacy-2026-05-04"
  // Per-user AI consent state. aiConsentDismissedAt is null until the user
  // clicks "I understand" in the AI consent modal for the first time;
  // AI endpoints 403 with code 'ai_consent_required' while null.
  aiConsentDismissedAt          DateTime?
  // "Don't ask me each session" persistent toggle (client-side modal
  // suppression only; the server-side gate is unchanged).
  aiConsentSilenced             Boolean   @default(false)
  // Record WHAT was consented to and WHICH provider was named at acceptance
  // time so consent isn't silently grandfathered when the modal text or
  // AI_PROVIDER changes.
  aiConsentVersion              String?
  aiConsentProviderAtAcceptance String? // "anthropic" | "openai" | "azure_openai" | "gemini"
  // ── Enterprise SSO / SCIM (feature/sso-polis) ───────────────────────────────
  // SCIM identity for directory-provisioned users. scimExternalId is Polis's
  // stable per-directory resource id (data.id in webhook events — identical
  // across create/update/deactivate); the IdP's own externalId is kept in the
  // event raw payload. Both NULL for ordinary password users (Postgres treats
  // NULLs as distinct, so the unique index below never collides on them).
  scimExternalId                String?
  scimDirectoryId               String?
  // True once a user is created/managed via SSO JIT or SCIM. Drives the
  // sso.required password-login block (break-glass is restricted to
  // non-ssoManaged admins).
  ssoManaged                    Boolean   @default(false)
  lastSsoLoginAt                DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  account                 Account                 @relation(fields: [accountId], references: [id])
  uploadedDocuments       Document[]              @relation("Uploader")
  communications          Communication[]         @relation("CommunicationCreator")
  reviewedIngestions      IngestionSession[]      @relation("IngestionReviewer")
  alertPreferences        AlertPreference[]
  activityLogs            ActivityLog[]
  sentInvites             UserInvite[]            @relation("InviteCreator")
  consultantAccesses      ConsultantAccess[]      @relation("ConsultantUser")
  grantedConsultants      ConsultantAccess[]      @relation("ConsultantGrantor")
  revokedConsultants      ConsultantAccess[]      @relation("ConsultantRevoker")
  refreshTokens           RefreshToken[]
  createdCustomFields     CustomFieldDefinition[] @relation("CustomFieldCreator")
  aiUsage                 AiUsage[]
  preferences             UserPreference[]
  notificationLogs        NotificationLog[]
  acknowledgedRevisions   StandardRevisionAlert[] @relation("RevisionAcknowledger")
  resolvedDeficiencies    Deficiency[]            @relation("DeficiencyResolver")
  complianceSnapshots     ComplianceSnapshot[]    @relation("SnapshotGenerator")
  ownedAssets             Asset[]                 @relation("AssetOwner")
  assignedRecommendations AuditRecommendation[]   @relation("RecAssignee")
  quoteRequests           QuoteRequest[]          @relation("QuoteRequestCreator")
  approvedLotoProcs       LotoProc[]              @relation("LotoProcApprover")
  createdLotoProcs        LotoProc[]              @relation("LotoProcCreator")
  declaredDisasters       DisasterEvent[]         @relation("DisasterDeclarer")
  sentPartnerInvites      PartnerInvite[]         @relation("PartnerInviter")
  assignedRepAccounts     Account[]               @relation("AssignedRep")
  fallbackRepAccounts     Account[]               @relation("FallbackRep")
  assignedEventLogs       PartnerEventLog[]       @relation("EventLogRep")
  ackedTelemetryNotifs    TelemetryNotification[] @relation("TelemetryNotificationAck")
  ssoHandoffs             SsoHandoff[]
  assignedWorkOrders      WorkOrder[]             @relation("WorkOrderAssignee")

  // SCIM upsert key: (directory, externalId) is unique per directory. Both
  // NULL for password users — Postgres NULLs are distinct so no collision.
  @@unique([scimDirectoryId, scimExternalId])
  @@index([accountId])
  // Password-reset lookups filter by passwordResetToken; without an index
  // every reset attempt is a full table scan.
  @@index([passwordResetToken])
  @@map("users")
}

// Cross-device user preferences (saved views, column visibility, other UI
// state that should follow the user across browsers/devices). One row per
// (user, key); `value` is Json so callers can stash arbitrary shape without
// schema churn. Cascades on user delete â€” preferences aren't audit-relevant.
model UserPreference {
  id        String   @id @default(uuid())
  userId    String
  key       String // e.g. "assets.columnVisibility", "alerts.savedViews"
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_preferences")
}

// â”€â”€â”€ Contractors (was Vendor) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// NETA-certified testing contractors who perform maintenance work. The
// per-account name uniqueness closes the duplicate-create race at the DB
// level (two concurrent CSV imports for the same contractor name).

model Contractor {
  id                String   @id @default(uuid())
  accountId         String
  name              String
  // In-house maintenance crew flag. NFPA 70B applies the same qualified-
  // person requirements regardless of employer; modeling internal staff as
  // a contractor row keeps work-order assignment uniform while letting the
  // UI label them honestly.
  isInternal        Boolean  @default(false)
  // NETA-accredited company flag. Work orders for tasks where
  // requiresNetaCertified=true should be assigned to accredited contractors;
  // enforced at the route layer with an override + audit trail.
  netaAccredited    Boolean  @default(false)
  notes             String?
  supportEmail      String?
  supportPhone      String?
  supportPortalUrl  String?
  portalUrl         String? // contractor scheduling/login portal
  scoreSupport      Int? // 1-5 rating
  scoreSatisfaction Int? // 1-5 overall rating
  aliases           Json? // string[] of org-specific alternate names / procurement codes
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account        Account          @relation(fields: [accountId], references: [id])
  techs          ContractorTech[]
  workOrders     WorkOrder[]
  communications Communication[]

  @@unique([accountId, name])
  @@index([accountId])
  @@map("contractors")
}

// Field technicians employed by a contractor; assignable to work orders.
model ContractorTech {
  id                          String         @id @default(uuid())
  contractorId                String
  name                        String
  email                       String?
  phone                       String?
  title                       String?
  // ANSI/NETA ETT certification level of this tech. Work orders carry the
  // minimum level required; assignment validation happens at the route layer.
  netaCertLevel               NetaCertLevel?
  // â”€â”€ Qualification provenance (NFPA 70E 110.2(A)(1) + insurer audits) â”€â”€â”€â”€
  // qualifiedPersonDesignatedAt: date of the EMPLOYER'S written qualified-
  // person designation (a training certificate alone is insufficient).
  // trainingExpiresAt: 70E retraining interval â‰¤3 years â€” drives an
  // "expiring qualification" surface later.
  // thermographerCertLevel: 'I' | 'II' | 'III' (Infraspection/ASNT model;
  // Level II is the de-facto insurer minimum for signing IR reports).
  qualifiedPersonDesignatedAt DateTime?
  trainingExpiresAt           DateTime?
  thermographerCertLevel      String?
  // â”€â”€ QEMW credential (ANSI/NETA EMW-2026, approved 2026-01-06) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  // ANSI/NETA EMW-2026 created the Qualified Electrical Equipment Maintenance
  // Worker (QEMW) certification. First-mover window ~12-18 months before
  // PowerDB/Accruent builds this. 3-year renewal cycle per the standard.
  qemwCertNumber              String? // certificate number issued by NETA
  qemwExpiresAt               DateTime? // expiry date (drives 60d + 14d alert cron)
  qemwIssuingBody             String? // "NETA" (only currently-recognized body)
  lastContactedAt             DateTime?
  notes                       String?
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  contractor Contractor  @relation(fields: [contractorId], references: [id])
  workOrders WorkOrder[]

  @@index([contractorId])
  @@map("contractor_techs")
}

// â”€â”€â”€ Asset Hierarchy â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// sites â†’ buildings â†’ areas â†’ equipment_positions â†’ assets
//
// The hierarchy is FLEXIBLE: an Asset always belongs to a Site, but the
// intermediate levels (building / area / position) are optional nullable
// links so small facilities can skip levels while large industrial sites use
// all five. The application layer validates chain consistency on write
// (e.g. asset.areaId must belong to asset.buildingId when both are set).

model Site {
  id                  String    @id @default(uuid())
  accountId           String
  name                String
  address             String?
  city                String?
  state               String?
  postalCode          String?
  // Customer-side contacts for alert routing (maintenance supervisor /
  // plant manager live as Users; this is the on-site coordination contact).
  primaryContactName  String?
  primaryContactEmail String?
  primaryContactPhone String?
  notes               String?
  archivedAt          DateTime? // soft-delete; assets keep their siteId
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  account             Account              @relation(fields: [accountId], references: [id])
  buildings           Building[]
  areas               Area[]
  positions           EquipmentPosition[]
  assets              Asset[]
  systemStudies       SystemStudy[]
  blackoutWindows     BlackoutWindow[]
  complianceSnapshots ComplianceSnapshot[]
  auditVisits         AuditVisit[]

  @@unique([accountId, name])
  @@index([accountId])
  @@index([accountId, archivedAt])
  @@map("sites")
}

model Building {
  id        String   @id @default(uuid())
  accountId String
  siteId    String
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site   Site    @relation(fields: [siteId], references: [id])
  areas  Area[]
  assets Asset[]

  @@unique([siteId, name])
  @@index([accountId])
  @@index([siteId])
  @@map("buildings")
}

model Area {
  id         String   @id @default(uuid())
  accountId  String
  siteId     String
  buildingId String? // optional â€” small sites may have areas directly under the site
  name       String
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  site      Site                @relation(fields: [siteId], references: [id])
  building  Building?           @relation(fields: [buildingId], references: [id])
  positions EquipmentPosition[]
  assets    Asset[]

  @@unique([siteId, name])
  @@index([accountId])
  @@index([siteId])
  @@index([buildingId])
  @@map("areas")
}

// A named physical slot equipment occupies â€” "Substation A, Cubicle 3",
// "MCC-1 Bucket 4B". Lets an asset swap (replace the transformer) keep the
// position's history intact.
model EquipmentPosition {
  id        String   @id @default(uuid())
  accountId String
  siteId    String
  areaId    String? // optional â€” positions can hang directly off a site
  name      String
  code      String? // short designation used on one-lines, e.g. "SWGR-1A"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site   Site    @relation(fields: [siteId], references: [id])
  area   Area?   @relation(fields: [areaId], references: [id])
  assets Asset[]

  @@unique([siteId, name])
  @@index([accountId])
  @@index([siteId])
  @@index([areaId])
  @@map("equipment_positions")
}

// â”€â”€â”€ Assets â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A piece of electrical equipment under maintenance management (was Contract
// in the inherited model).

model Asset {
  id                            String          @id @default(uuid())
  accountId                     String
  siteId                        String
  buildingId                    String?
  areaId                        String?
  positionId                    String?
  equipmentType                 EquipmentType
  manufacturer                  String?
  model                         String?
  serialNumber                  String?
  // Nameplate fields vary wildly by equipment type (kVA + primary/secondary
  // voltage for transformers, kW + RPM for generators, AIC rating for
  // breakers...) â€” JSONB with per-type Zod validation at the route layer.
  nameplateData                 Json?
  installDate                   DateTime?
  lastCommissionedDate          DateTime?
  // NFPA 70B:2023 three-axis condition assessment. Defaults to C2 (base
  // interval) until a qualified person assesses the asset.
  conditionPhysical             ConditionRating @default(C2)
  conditionCriticality          ConditionRating @default(C2)
  conditionEnvironment          ConditionRating @default(C2)
  // Responsible person for this asset. Drives alert routing (owner receives
  // every tier for their assets, in addition to the role matrix) and the
  // "equipment owner" answer auditors expect. Nullable â€” unowned assets
  // fall back to pure role routing.
  ownerId                       String?
  // Electrical topology: the asset this one is FED FROM (its upstream
  // source). Self-relation forming the power-path graph â€” upstream chain =
  // walk fedFrom links to the source; downstream = children of this node.
  // Drives the Power Path card and outage-impact answers ("de-energize this
  // switchgear â†’ these N assets lose power"). Cycle prevention enforced at
  // the route layer (a feed loop is always data-entry error).
  fedFromAssetId                String?
  // â”€â”€ Risk dimensions (2026-06-07 buyer-priority analysis) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  // Three axes beyond the NFPA 70B condition assessment: infrastructure
  // criticality (consequence of failure), financial exposure (repair cost +
  // spare-parts lead time), and resilience posture. These drive the priority
  // dashboard tabs (critical infrastructure / high-value / high-volume) and
  // sorting on the asset list. All optional â€” unscored assets sort last.
  // NOTE: criticalityScore (1=low â€¦ 5=failure means injury/shutdown/fines)
  // is INFRASTRUCTURE criticality and deliberately separate from
  // conditionCriticality (the NFPA 70B C1-C3 maintenance-interval axis).
  criticalityScore              Int?
  // Degradation score (1=good â€¦ 5=severe) on the physical-condition axis.
  // Distinct from conditionPhysical/conditionCriticality/conditionEnvironment
  // (those are NFPA 70B C1-C3 maintenance-interval ratings). This integer
  // enables the Degradation Priority Score: DPS = conditionScore Ã— criticalityScore
  // (range 1â€“25, higher = more urgent service needed).
  conditionScore                Int?
  // Stored DPS: conditionScore Ã— criticalityScore. Recomputed by the route
  // layer whenever either input changes so list queries can ORDER BY without
  // a computed expression. NULL when either factor is NULL.
  priorityScore                 Int?
  repairCostEstimate            Decimal?        @db.Decimal(14, 2) // parts + labor + downtime, USD
  spareLeadTimeWeeks            Int? // long-lead spares risk (transformers can be 50+ weeks)
  redundancyStatus              String? // N | N_PLUS_1 | TWO_N
  requiresPredictiveMaintenance Boolean         @default(false) // oil/DGA, PD, vibration class
  // Governing condition = worst of the three axes (C3 wins). Stored and
  // recomputed by the route layer on every condition write so list queries
  // and the scheduler never re-derive it. Drives interval selection on
  // MaintenanceTaskDefinition (intervalC1/C2/C3Months).
  governingCondition            ConditionRating @default(C2)
  // NFPA 70B Â§9.3.1: an asset that has missed its last two successive
  // maintenance cycles is treated as Condition 3. Computed by the daily
  // missedCyclePolicy cron as a SEPARATE governing input (worst-of also
  // considers this flag) so it tightens every interval WITHOUT overwriting a
  // qualified person's physical/criticality/environment assessment. Cleared
  // automatically once maintenance catches up.
  autoConditionC3               Boolean         @default(false)
  // Phase 4 #8: set true while the asset has >=1 OPEN (unacknowledged) CRIT
  // continuous-monitoring notification. A SEPARATE governing input (worst-of
  // also considers this flag as a C2 driver) so an unaddressed telemetry
  // breach tightens the interval to the Condition-2 base WITHOUT overwriting a
  // qualified person's physical/criticality/environment assessment. Cleared
  // automatically when the channel returns to OK or a reviewer acknowledges.
  // Mirrors autoConditionC3 (NFPA 70B:2023 condition-based maintenance).
  autoConditionMonitoring       Boolean         @default(false)
  inService                     Boolean         @default(true)
  isEnergized                   Boolean         @default(true)
  notes                         String?
  archivedAt                    DateTime? // soft-delete; history (work orders, samples) stays addressable
  // â”€â”€ EOL / Obsolescence (Task 23 â€” Modernization Revenue Engine) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  // OEM-published lifecycle dates. When endOfSupport is set the
  // modernizationRiskScore cron normalises over a 5-year window
  // (see lib/modernizationAlerts.ts). When null, the cron falls back to the
  // IEEE/NFPA base-life + condition-multiplier heuristic.
  // Backlog: expose these via outbound webhook/API so OEM CRMs (Brightlayer,
  // EcoStruxure, ABB Ability, Xcelerator) can pull asset health scores.
  endOfManufacture              DateTime? // OEM last manufacture date
  endOfSupport                  DateTime? // OEM last support/parts date
  obsolescenceStatus            String? // ACTIVE | ACTIVE_UNSUPPORTED | DISCONTINUED | OBSOLETE
  criticalSparesAvailable       Boolean? // true = spares in OEM/distributor inventory
  sparePartsLeadTimeDays        Int? // estimated lead time (days) for critical spares
  replacementCostCents          Int? // all-in replacement estimate (USD cents)
  modernizationRiskScore        Float? // 0-1+ RUL score; recomputed daily by modernizationAlerts cron
  createdAt                     DateTime        @default(now())
  updatedAt                     DateTime        @updatedAt

  account                Account                 @relation(fields: [accountId], references: [id])
  site                   Site                    @relation(fields: [siteId], references: [id])
  building               Building?               @relation(fields: [buildingId], references: [id])
  area                   Area?                   @relation(fields: [areaId], references: [id])
  position               EquipmentPosition?      @relation(fields: [positionId], references: [id])
  owner                  User?                   @relation("AssetOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  fedFrom                Asset?                  @relation("PowerPath", fields: [fedFromAssetId], references: [id], onDelete: SetNull)
  feedsDownstream        Asset[]                 @relation("PowerPath")
  schedules              MaintenanceSchedule[]
  workOrders             WorkOrder[]
  deficiencies           Deficiency[]
  labSamples             LabSample[]
  documents              Document[]
  communications         Communication[]
  alerts                 Alert[]
  activityLogs           ActivityLog[]
  customFieldValues      CustomFieldValue[]
  quoteRequests          QuoteRequest[]
  lotoProcs              LotoProc[]
  incidentLogs           IncidentLog[]
  studyAssets            SystemStudyAsset[]
  telemetryChannels      TelemetryChannel[]
  telemetryReadings      TelemetryReading[]
  telemetryNotifications TelemetryNotification[]

  @@index([accountId])
  @@index([accountId, siteId])
  @@index([accountId, equipmentType])
  @@index([accountId, archivedAt])
  @@index([positionId])
  @@index([fedFromAssetId])
  @@map("assets")
}

// â”€â”€â”€ Compliance Standards â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Governing standards (NFPA 70B/70E/110, NETA MTS/ATS, IEEE C57.104/43,
// OSHA 1910-S). GLOBAL â€” no accountId; no public APIs exist for NFPA/NETA
// content so editions are seeded as data and updated via the manual
// revision workflow (StandardRevisionAlert).

model ComplianceStandard {
  id            String    @id @default(uuid())
  code          String // "NFPA 70B", "NETA MTS", "IEEE C57.104", ...
  edition       String // "2023", "2024", "2019", ...
  publisher     String // NFPA | NETA | IEEE | OSHA
  title         String
  keyMandate    String? // e.g. "Mandatory EMP, condition-based intervals"
  revisionCycle String? // e.g. "3-5yr", "irregular", "ongoing"
  effectiveDate DateTime?
  supersededAt  DateTime? // set when a newer edition row replaces this one
  sourceUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  taskDefinitions MaintenanceTaskDefinition[]
  revisionAlerts  StandardRevisionAlert[]

  @@unique([code, edition])
  @@map("compliance_standards")
}

// â”€â”€â”€ Maintenance Task Definitions â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// The NFPA 70B / NETA Appendix B interval matrix: what maintenance each
// equipment type needs and how often, per condition rating.
//
// Rows with accountId = NULL are the global seeded matrix shared by all
// tenants (standards updates patch one place). Rows with accountId set are
// tenant-defined custom tasks. NOTE: the @@unique below does not constrain
// global rows in Postgres (NULL != NULL) â€” the seed script enforces
// global-row uniqueness by deterministic taskCode upsert.

model MaintenanceTaskDefinition {
  id                    String         @id @default(uuid())
  accountId             String? // NULL = global seed row; set = tenant custom task
  standardId            String?
  equipmentType         EquipmentType
  taskName              String // "IR thermography scan"
  taskCode              String // stable machine code, e.g. "SWGR_IR_THERMO"
  description           String?
  // Interval in months per NFPA 70B governing condition. C2 is the base
  // (NETA published) interval; C1 stretches (Ã—2.5, ceiling 60 months);
  // C3 compresses (Ã—0.25, ceiling 12 months). Stored explicitly rather than
  // derived so seed data can carry the exact NETA Appendix B values.
  intervalC1Months      Int?
  intervalC2Months      Int
  intervalC3Months      Int?
  requiresOutage        Boolean        @default(false) // de-energized work â€” needs blackout window
  requiresEnergized     Boolean        @default(false) // e.g. IR thermography needs load
  requiresNetaCertified Boolean        @default(false)
  netaCertLevelMin      NetaCertLevel?
  standardRef           String? // e.g. "NFPA 70B:2023 s9.7.3"
  archivedAt            DateTime? // soft-retire; existing schedules keep the FK
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  account       Account?              @relation(fields: [accountId], references: [id])
  standard      ComplianceStandard?   @relation(fields: [standardId], references: [id])
  schedules     MaintenanceSchedule[]
  templateTasks AssetTemplateTask[]

  @@unique([accountId, equipmentType, taskCode])
  @@index([equipmentType])
  @@index([accountId])
  @@index([standardId])
  @@map("maintenance_task_definitions")
}

// â”€â”€â”€ Maintenance Schedules â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// One row per (asset, task) pairing â€” the living recurrence record.
// nextDueDate is stored, recomputed on completion / condition change:
//   nextDueDate = lastCompletedDate + interval months for the asset's
//   governing condition (or conditionOverride when set).

model MaintenanceSchedule {
  id                     String           @id @default(uuid())
  accountId              String
  assetId                String
  taskDefinitionId       String
  lastCompletedDate      DateTime?
  nextDueDate            DateTime? // null until first completion or manual anchor
  // Alert lead times. Scheduling lead (180d default) opens the engineer
  // booking window for the contractor; customer lead (90d default) starts
  // customer-side planning notices.
  leadTimeSchedulingDays Int              @default(180)
  leadTimeCustomerDays   Int              @default(90)
  // Per-schedule condition override â€” e.g. a C1 asset whose battery string
  // the engineer insists on treating as C3. Null = use asset.governingCondition.
  conditionOverride      ConditionRating?
  // Provenance for completions recorded without a work order: who actually
  // performed the task (free text â€” name + employer). WO-based completions
  // carry richer provenance on the work order itself.
  lastPerformedByName    String?
  isActive               Boolean          @default(true)
  notes                  String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  account        Account                   @relation(fields: [accountId], references: [id])
  asset          Asset                     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  taskDefinition MaintenanceTaskDefinition @relation(fields: [taskDefinitionId], references: [id])
  workOrders     WorkOrder[]
  alerts         Alert[]

  @@unique([assetId, taskDefinitionId])
  @@index([accountId])
  // THE hot path: dashboard "due in 30/60/90", alert engine sweep, and the
  // compliance calendar all filter on (accountId, nextDueDate).
  @@index([accountId, nextDueDate])
  @@index([accountId, isActive, nextDueDate])
  @@index([assetId])
  @@map("maintenance_schedules")
}

// â”€â”€â”€ Work Orders â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model WorkOrder {
  id               String           @id @default(uuid())
  accountId        String
  scheduleId       String? // null for ad-hoc / corrective work
  assetId          String
  // #22 closed-loop attribution: set when this WO was auto-created from an
  // accepted QuoteRequest, so "quotes via ServiceCycle -> completed work" is a
  // queryable number and completion clears the originating compliance gap.
  quoteRequestId   String?
  contractorId     String?
  assignedTechId   String?
  // Direct work-order -> login-user assignment (field-labor / subcontractor).
  // Distinct from assignedTechId, which points at a ContractorTech record (not
  // a login). A field_tech user's entire world is the set of work orders where
  // assignedUserId = their id; the /api/field surface scopes to it.
  assignedUserId   String?
  // Minimum NETA cert level required for this job (from the task definition
  // at creation time; editable).
  netaCertLevel    NetaCertLevel?
  status           WorkOrderStatus  @default(SCHEDULED)
  scheduledDate    DateTime?
  startedAt        DateTime?
  completedDate    DateTime?
  // NETA MTS as-found / as-left condition of maintenance.
  asFoundCondition ConditionRating?
  asLeftCondition  ConditionRating?
  // NETA decal color affixed after testing. NOTE: NETA MTS Â§5.5 colors are
  // WHITE (serviceable) / YELLOW (limited service) / RED (non-serviceable);
  // the enum's GREEN value renders as "Serviceable" in the UI.
  netaDecal        ResultRating?
  // â”€â”€ Test-condition + instrument provenance (NETA MTS Â§5.4.2 #4, Â§5.3) â”€â”€
  // Ambient conditions at test time and the calibrated instruments used.
  // testEquipment: [{ make, model, serial, calDate }] â€” calibration must be
  // within 12 months of the test date, NIST-traceable.
  ambientTempC     Decimal?         @db.Decimal(5, 1)
  humidityPct      Decimal?         @db.Decimal(5, 1)
  testEquipment    Json?
  // #27 NFPA 70B year-0 baseline: an acceptance / commissioning test is the
  // trend anchor for the asset's life (vs. "first maintenance test wins").
  // Set on test-report ingest; the test-history endpoint surfaces it as the
  // baseline event and the ingest path skips YoY trend flags on it.
  isAcceptanceTest Boolean          @default(false)
  reportPdfUrl     String? // contractor-issued test report (also attachable via Document)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  account      Account              @relation(fields: [accountId], references: [id])
  schedule     MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  asset        Asset                @relation(fields: [assetId], references: [id])
  quoteRequest QuoteRequest?        @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  contractor   Contractor?          @relation(fields: [contractorId], references: [id])
  assignedTech ContractorTech?      @relation(fields: [assignedTechId], references: [id])
  assignedUser User?                @relation("WorkOrderAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  measurements TestMeasurement[]
  deficiencies Deficiency[]
  labSamples   LabSample[]
  documents    Document[]

  @@index([accountId])
  @@index([accountId, status])
  @@index([accountId, scheduledDate])
  @@index([assetId])
  @@index([scheduleId])
  @@index([contractorId])
  @@index([assignedUserId])
  @@map("work_orders")
}

// â”€â”€â”€ Test Measurements â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// NETA MTS 5.4 requires BOTH as-found and as-left values recorded.

model TestMeasurement {
  id               String        @id @default(uuid())
  accountId        String
  workOrderId      String
  measurementType  String // "insulation_resistance", "contact_resistance", "ttr", ...
  phase            String? // "A" | "B" | "C" | "N" | "A-B" ... free-form per test type
  asFoundValue     Decimal?      @db.Decimal(16, 4)
  asFoundUnit      String? // "MÎ©", "ÂµÎ©", "Â°C", ...
  asLeftValue      Decimal?      @db.Decimal(16, 4)
  asLeftUnit       String?
  passFail         ResultRating?
  // NETA MTS Â§5.4.2 #8: expected results placed beside actuals for direct
  // comparison (e.g. "â‰¥100 MÎ© per NETA Table 100.1", "Â±20% of trip curve").
  expectedRange    String?
  testVoltage      String? // applied test voltage, e.g. "1000 V DC"
  // IR thermography fields (Infraspection/NETA): load at scan time must be
  // recorded (â‰¥40% rule per HSB/Zurich); severityPriority is the NETA Î”T
  // priority 1 (repair immediately) â€¦ 4 (possible deficiency).
  loadPercent      Decimal?      @db.Decimal(5, 1)
  severityPriority Int?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  // Forensics/immutability: deleting a reading (evidence) is a SOFT delete -
  // the row is retained with deletedAt set and excluded from all reads, so a
  // reading can be reconstructed/recovered rather than truly vanishing.
  deletedAt        DateTime?

  account   Account   @relation(fields: [accountId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([workOrderId])
  @@map("test_measurements")
}

// â”€â”€â”€ Deficiencies â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Findings from testing/inspection. IMMEDIATE = safety/operation risk now;
// RECOMMENDED = correct at next opportunity; ADVISORY = monitor.

model Deficiency {
  id               String             @id @default(uuid())
  accountId        String
  workOrderId      String? // null when logged outside a work order (walkthrough finding)
  assetId          String
  severity         DeficiencySeverity
  description      String
  correctiveAction String?
  resolvedAt       DateTime?
  resolvedById     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  account    Account    @relation(fields: [accountId], references: [id])
  workOrder  WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  asset      Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  resolvedBy User?      @relation("DeficiencyResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([accountId])
  // Dashboard "overdue/open deficiencies by severity" tile.
  @@index([accountId, severity, resolvedAt])
  @@index([assetId])
  @@index([workOrderId])
  @@map("deficiencies")
}

// â”€â”€â”€ Incident / protective-device-operation log (#24, NFPA 70B EMP element 9) â”€â”€
// Quick field/asset log of breaker trips, relay operations, and alarms. NFPA
// 70B requires the program to USE incident feedback (Â§9.3.1 condition criteria
// reference unaddressed notifications); this is the ground-truth stream between
// test cycles that feeds the EMP's incident section and condition assessment.

enum IncidentType {
  PROTECTIVE_TRIP // breaker / protective device tripped
  RELAY_OPERATION // protective relay operated
  ALARM // alarm / annunciator activation
  ARC_FLASH_EVENT // arc-flash / arcing event
  OTHER
}

// â”€â”€â”€ Auditor / insurer share link (#21) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A time-boxed, revocable, read-only token that exposes a watermarked
// compliance package (honest number + Path-to-100 + latest snapshot) to an
// underwriter or auditor without giving them an account. No PII beyond the
// company name and compliance posture is exposed through the public view.
model ShareLink {
  id           String    @id @default(uuid())
  accountId    String
  token        String    @unique
  kind         String    @default("compliance_package")
  label        String? // recipient/underwriter name, shown in the watermark
  expiresAt    DateTime
  revokedAt    DateTime?
  createdById  String?
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  createdAt    DateTime  @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([token])
  @@map("share_links")
}

// â”€â”€â”€ Public parser-as-funnel lead (#17) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A prospect who dropped a report on the public, email-gated parser page. No
// account yet â€” this is top-of-funnel lead capture. Raw IP is never stored
// (hashed for abuse tracking only); the parsed report itself is not retained.
model PublicParseLead {
  id               String   @id @default(uuid())
  email            String
  fileName         String?
  source           String? // deterministic engine that read it
  measurementCount Int      @default(0)
  findingsCount    Int      @default(0)
  criticalCount    Int      @default(0)
  ipHash           String? // sha256 of IP â€” abuse signal, not PII
  createdAt        DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("public_parse_leads")
}

model IncidentLog {
  id           String       @id @default(uuid())
  accountId    String
  assetId      String
  type         IncidentType @default(OTHER)
  occurredAt   DateTime
  note         String?
  // Resolution / acknowledgement â€” an unaddressed incident is a C2/C3 input.
  resolvedAt   DateTime?
  resolvedById String?
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  account Account @relation(fields: [accountId], references: [id])
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([assetId])
  @@index([accountId, resolvedAt])
  @@map("incident_logs")
}

// â”€â”€â”€ System Studies â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Site-level engineering studies â€” the documents loss-control auditors ask
// for by name. studyType:
//   arc_flash       â€” NFPA 70E 130.5 incident-energy analysis; review â‰¤5yr
//   short_circuit   â€” fault-current study; â‰¤5yr or after system changes
//   coordination    â€” protective device coordination study; same cadence
//   one_line_review â€” dated confirmation the one-line diagram reflects the
//                     actual system (HSB: update drawings on every change)
// PE provenance (peName/peLicense) is the consistent insurer expectation
// for incident-energy and coordination work.
//
// Renamed from ArcFlashStudy 2026-06-07 (audit-records research): the model
// now carries all four study types; the underlying table was renamed in the
// same migration (fresh-PoC DBs only â€” no production data existed).

model SystemStudy {
  id             String   @id @default(uuid())
  accountId      String
  siteId         String
  studyType      String   @default("arc_flash") // arc_flash | short_circuit | coordination | one_line_review
  performedDate  DateTime
  expiresAt      DateTime // performedDate + 5yr; engine flags approaching expiry
  performedBy    String? // engineering firm name
  // Method + responsible engineer (e.g. "IEEE 1584-2018"; PE name/license
  // on the report cover is what auditors look for).
  method         String?
  peName         String?
  peLicense      String?
  // Why a re-study happened before the 5yr clock: "system_change",
  // "utility_change", "scheduled" â€” free-form for PoC.
  trigger        String?
  reportPdfUrl   String?
  notes          String?
  supersededById String? // newer study that replaces this one
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account       Account            @relation(fields: [accountId], references: [id])
  site          Site               @relation(fields: [siteId], references: [id])
  supersededBy  SystemStudy?       @relation("StudyChain", fields: [supersededById], references: [id])
  supersedes    SystemStudy[]      @relation("StudyChain")
  coveredAssets SystemStudyAsset[]
  sourceModel   StudySourceModel? // slice E: utility/transformer/motor/generator source model

  @@index([accountId])
  @@index([accountId, expiresAt])
  @@index([siteId, studyType])
  @@map("system_studies")
}

// â”€â”€â”€ Arc-flash / system-study asset coverage (#25) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Binds a SystemStudy (esp. arc_flash) to the assets/buses it covers, carrying
// the per-bus incident-energy label data NFPA 70E Â§130.5(H) requires posted ON
// the equipment (nominal voltage, arc-flash boundary, incident energy + working
// distance OR PPE category, plus the study date). Assets are bound directly or
// expanded down the power-path graph (feedsDownstream). One row per (study,
// asset); the per-study 5-yr clock lives on SystemStudy.expiresAt.
model SystemStudyAsset {
  id                   String   @id @default(uuid())
  accountId            String // denormalized for tenancy scoping (no Account back-rel needed)
  studyId              String
  assetId              String
  busName              String? // bus / equipment designation on the study one-line
  nominalVoltage       String? // e.g. "480V", "13.8kV"
  incidentEnergyCalCm2 Decimal? @db.Decimal(10, 2) // cal/cm^2 at working distance
  arcFlashBoundaryIn   Decimal? @db.Decimal(10, 1) // arc-flash boundary, inches
  workingDistanceIn    Decimal? @db.Decimal(10, 1) // working distance, inches
  ppeCategory          Int? // NFPA 70E PPE category 0-4 (null when incident-energy method used)
  // ─── IEEE 1584-2018 calculation inputs (the "infrastructure" that produced
  // the incident energy above). Capturing these per bus per study revision is
  // what powers incident-energy trending, the >40 cal/cm² DANGER threshold, and
  // what-if recompute when a protective device changes. All optional — a study
  // may only ship the label outputs.
  boltedFaultCurrentKA Decimal? @db.Decimal(10, 2) // 3φ bolted fault current, kA
  arcingCurrentKA      Decimal? @db.Decimal(10, 2) // arcing current, kA
  electrodeConfig      ElectrodeConfig? // IEEE 1584 electrode config: VCB|VCBB|HCB|VOA|HOA
  conductorGapMm       Decimal? @db.Decimal(6, 1) // conductor gap, mm
  clearingTimeMs       Decimal? @db.Decimal(10, 1) // upstream protective-device clearing time, ms
  upstreamDevice       String? // protective device that clears this bus (label/free text)
  // ─── Durable protective-device + feeder-cable record (Slice 2.7+ "build it
  // out"). The ingest draft (ArcFlashIngestBus) collected these and the new
  // ProtectiveDevice table holds the live version; persist them HERE too so each
  // study revision keeps its own snapshot and the record can be tracked
  // study-over-study (the year-over-year axis) without losing the field data.
  // Names mirror ArcFlashIngestBus. (Richer fields — enclosure dims, arc rating,
  // shock boundaries, mitigation flags, trip-unit/fuse enums — are the
  // PE-reviewed schema-bootstrap migration; see ARC_FLASH_DOMAIN_MODEL.md.)
  deviceType           String? // breaker | fuse | relay | switch
  tripUnitType         TripUnitType? // adjustable (electronic_lsi/lsig) => settings required; else not
  fuseClass            FuseClass? // when deviceType = fuse
  deviceManufacturer   String?
  deviceModel          String?
  deviceRatingA        Decimal? @db.Decimal(10, 1) // frame / sensor amp rating
  deviceSettings       Json? // LSIG trip settings or fuse class+rating
  cableLengthFt        Decimal? @db.Decimal(10, 1)
  cableSize            String?
  cableMaterial        String? // Cu | Al
  conductorsPerPhase   Int? // slice E: # conductors per phase (cable impedance)
  conduitType          String? // slice E: steel | pvc | al (conduit reactance)
  // --- Slice B: outcome / label (study results) ---
  requiredArcRatingCalCm2   Decimal?       @db.Decimal(10, 2) // min arc rating (ATPV/EBT) for the incident-energy PPE method
  ppeMethod                 PpeMethod? // which method this label uses
  shockLimitedApproachIn    Decimal?       @db.Decimal(10, 1)
  shockRestrictedApproachIn Decimal?       @db.Decimal(10, 1)
  labelSeverity             LabelSeverity? // derived DANGER (>40 cal or >600 V) / WARNING
  // --- Slice D: enclosure (IEEE 1584-2018 size correction) ---
  enclosureType             EnclosureType?
  enclosureHeightMm         Decimal?       @db.Decimal(8, 1)
  enclosureWidthMm          Decimal?       @db.Decimal(8, 1)
  enclosureDepthMm          Decimal?       @db.Decimal(8, 1)
  // --- Slice F: mitigation + dual-scenario ---
  ermsPresent               Boolean?
  zsiEnabled                Boolean?
  differentialPresent       Boolean?
  arcResistant              Boolean?
  nec24087Method            String? // documented arc-energy-reduction method when trip setting >= 1200 A
  calcMethod                CalcMethod?
  arcingCurrentReducedKA    Decimal?       @db.Decimal(10, 2) // reduced (VarCf) arcing-current scenario
  governingScenario         String? // "full" | "reduced" - which gave the higher energy
  // --- Slice 3.5c: live QR/NFC label-as-portal + printed-vs-current mismatch ---
  publicToken               String?        @unique // unguessable; the QR/NFC encodes a public URL carrying it
  printedSnapshot           Json? // label values captured when the physical label was last issued/printed
  printedAt                 DateTime? // when the physical label was last issued/printed
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  study SystemStudy @relation(fields: [studyId], references: [id], onDelete: Cascade)
  asset Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([studyId, assetId])
  @@index([accountId])
  @@index([studyId])
  @@index([assetId])
  @@map("system_study_assets")
}

// ─── Slice E: arc-flash source / system model ────────────────────────────────
// The not-per-bus inputs that feed the short-circuit study which produces the
// available fault current at every bus: the utility at the point of common
// coupling (MAX and MIN fault + X/R), the main transformer, and motor/generator
// fault contributions. One per SystemStudy. Scalar FK to the study (additive).
model StudySourceModel {
  id        String @id @default(uuid())
  accountId String
  siteId    String
  studyId   String @unique
  // Utility / point of common coupling — the root of the whole fault tree.
  utilityMaxFaultKA Decimal? @db.Decimal(10, 2) // worst-case available fault current
  utilityMinFaultKA Decimal? @db.Decimal(10, 2) // min case can govern (slower arcing)
  utilityXr         Decimal? @db.Decimal(10, 2) // X/R at the service entrance
  // Main transformer (determines secondary fault current).
  transformerKva          Decimal? @db.Decimal(12, 2)
  transformerPrimaryV     Int?
  transformerSecondaryV   Int?
  transformerImpedancePct Decimal? @db.Decimal(6, 2) // %Z
  transformerXr           Decimal? @db.Decimal(10, 2)
  transformerConnection   String? // e.g. delta-wye
  // Motor + generator contributions (no 50 HP exemption in IEEE 1584-2018).
  motorContributionHp        Int? // total connected HP contributing fault current
  motorContributionCount     Int?
  generatorKva               Decimal? @db.Decimal(12, 2)
  generatorVoltageV          Int?
  generatorSubtransientXdPct Decimal? @db.Decimal(6, 2) // Xd"
  // IEEE 1584-2018 sec 4.3: surface (never auto-apply) the old <125 kVA / <240 V flag.
  below125kvaFlag Boolean?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  study SystemStudy @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([siteId])
  @@map("study_source_models")
}

// â”€â”€â”€ Audit Visits + Recommendations â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// First-class record of audits: insurance loss-control visits, OSHA
// inspections, internal pre-audit walkthroughs, customer/AHJ audits.
// Recommendations (RECs) mirror the carrier workflow: written response
// expected within 30â€“45 days, completion tracked, consequences escalate.
// Snapshots generated for an audit link back via ComplianceSnapshot.auditVisitId
// â€” the audit record points at the exact hash-anchored evidence handed over.

model AuditVisit {
  id            String    @id @default(uuid())
  accountId     String
  siteId        String? // null = account-wide audit
  auditType     String // insurance | osha | internal_preaudit | customer | ahj
  auditorName   String?
  auditorOrg    String? // carrier / agency / firm
  scheduledDate DateTime?
  performedDate DateTime?
  outcome       String? // passed | passed_with_findings | failed | pending
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  account         Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  site            Site?                 @relation(fields: [siteId], references: [id], onDelete: SetNull)
  recommendations AuditRecommendation[]
  snapshots       ComplianceSnapshot[]

  @@index([accountId, performedDate(sort: Desc)])
  @@index([siteId])
  @@map("audit_visits")
}

model AuditRecommendation {
  id               String    @id @default(uuid())
  accountId        String
  auditVisitId     String?
  source           String    @default("insurer") // insurer | osha | internal | customer | ahj
  severity         String    @default("recommendation") // mandatory | recommendation
  description      String
  dueDate          DateTime? // carrier response/completion deadline
  status           String    @default("open") // open | responded | completed | declined
  responseNotes    String? // the written response sent back to the carrier
  respondedAt      DateTime?
  completedAt      DateTime?
  assignedToUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  auditVisit AuditVisit? @relation(fields: [auditVisitId], references: [id], onDelete: SetNull)
  assignedTo User?       @relation("RecAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([accountId, status, dueDate])
  @@index([auditVisitId])
  @@map("audit_recommendations")
}

// â”€â”€â”€ Lab Samples â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// DGA / oil quality / fuel analysis results. Gas columns in ppm per
// IEEE C57.104-2019 dissolved gas analysis. Non-DGA sample types leave the
// gas columns null and carry results in `resultsData`.

model LabSample {
  id           String        @id @default(uuid())
  accountId    String
  assetId      String
  workOrderId  String? // sample may be pulled during a work order
  sampleType   String // "dga" | "oil_quality" | "fuel" (string, not enum â€” lab menus grow)
  sampleDate   DateTime
  labName      String?
  // IEEE C57.104 DGA gases, ppm.
  h2           Decimal?      @db.Decimal(10, 2)
  ch4          Decimal?      @db.Decimal(10, 2)
  c2h2         Decimal?      @db.Decimal(10, 2)
  c2h4         Decimal?      @db.Decimal(10, 2)
  c2h6         Decimal?      @db.Decimal(10, 2)
  co           Decimal?      @db.Decimal(10, 2)
  co2          Decimal?      @db.Decimal(10, 2)
  // O2 + N2 complete the IEEE C57.104-2019 gas set; the O2/N2 ratio
  // distinguishes sealed vs free-breathing units and selects which
  // reference table applies.
  o2           Decimal?      @db.Decimal(10, 2)
  n2           Decimal?      @db.Decimal(10, 2)
  // IEEE C57.104-2019 DGA status (1 = normal, 2 = caution â‰¥90th pct,
  // 3 = action required â‰¥95th pct) and the fault diagnosis code from
  // Duval/Rogers interpretation (PD, T1, T2, T3, D1, D2).
  ieeeStatus   Int?
  faultCode    String?
  // Non-DGA results (dielectric strength, moisture, acidity, fuel
  // contamination...) â€” sparse per-type shape, JSONB like nameplateData.
  resultsData  Json?
  resultRating ResultRating?
  reportPdfUrl String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  account   Account    @relation(fields: [accountId], references: [id])
  asset     Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([assetId, sampleDate])
  @@index([workOrderId])
  @@map("lab_samples")
}

// â”€â”€â”€ Blackout Windows â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Customer-declared downtime windows. The scheduler avoids proposing
// requiresOutage work outside these, and avoids ALL work inside windows
// marked as no-work periods (production freeze).

model BlackoutWindow {
  id             String   @id @default(uuid())
  accountId      String
  siteId         String
  startsAt       DateTime
  endsAt         DateTime
  // true  = this window is WHEN outage work may happen (planned shutdown)
  // false = this window is a freeze â€” no work may be scheduled inside it
  isOutageWindow Boolean  @default(true)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([siteId, startsAt])
  @@map("blackout_windows")
}

// â”€â”€â”€ Standard Revision Alerts â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// When NFPA/NETA publishes a new edition (tracked via email list + manual
// update workflow â€” no public API), one row is created per account flagging
// schedules whose intervals may change. Acknowledged per-account by an admin.

model StandardRevisionAlert {
  id                    String    @id @default(uuid())
  accountId             String
  standardId            String
  newEdition            String // e.g. "2026"
  publishedAt           DateTime
  summary               String? // what changed, human-written during the update workflow
  affectedScheduleCount Int?
  acknowledgedAt        DateTime?
  acknowledgedById      String?
  createdAt             DateTime  @default(now())

  account        Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  standard       ComplianceStandard @relation(fields: [standardId], references: [id])
  acknowledgedBy User?              @relation("RevisionAcknowledger", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([accountId, acknowledgedAt])
  @@index([standardId])
  @@map("standard_revision_alerts")
}

// â”€â”€â”€ Compliance Snapshots â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Point-in-time audit evidence packs. A snapshot is GENERATED AND STORED â€”
// never regenerated from live data â€” so "show me your compliance posture
// from March" has a real answer. The PDF's SHA-256 is recorded both here and
// in an ActivityLog row (action compliance_snapshot_generated), which the
// per-account tamper-evident hash chain then covers: the snapshot's
// existence-at-date and integrity are cryptographically provable to an
// auditor or insurance carrier. The file itself lives in document storage
// (filePath is the storage key, same convention as Document.filePath).

model ComplianceSnapshot {
  id            String   @id @default(uuid())
  accountId     String
  siteId        String? // null = all sites in the account
  standardCode  String? // e.g. "NFPA 70B"; null = all standards
  // kind: 'compliance' = per-standard evidence pack; 'emp' = the generated
  // written EMP document (NFPA 70B Â§4.2) â€” same immutable-storage +
  // hash-chain-anchor pipeline, different renderer.
  kind          String   @default("compliance")
  // When generated for a specific audit, links the evidence to the visit.
  auditVisitId  String?
  generatedById String?
  filename      String
  filePath      String // storage key (path on disk or S3 object key)
  sizeBytes     Int?
  sha256        String // integrity hash; also in the audit-log row's details
  stats         Json? // counts at generation time { assets, schedules, current, overdue, openDeficiencies }
  createdAt     DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  site        Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)
  generatedBy User?       @relation("SnapshotGenerator", fields: [generatedById], references: [id], onDelete: SetNull)
  auditVisit  AuditVisit? @relation(fields: [auditVisitId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt(sort: Desc)])
  @@map("compliance_snapshots")
}

// Missing-access / open-items blocker log. Assets that couldn't be fully
// inspected (locked door, outage needed, missing label, access limit) recorded
// as customer-owned blockers tied to a compliance impact. Scalar-only by design
// (no Prisma relations) so it adds zero churn to Account/Site/Asset/User;
// referential integrity + tenant-cascade is enforced by the SQL foreign keys in
// migration 20260619000000_access_blockers.
model AccessBlocker {
  id           String    @id @default(uuid())
  accountId    String
  siteId       String?
  assetId      String?
  kind         String // LOCKED_DOOR | OUTAGE_NEEDED | MISSING_LABEL | ACCESS_LIMIT | OTHER
  description  String?
  status       String    @default("open") // open | resolved
  createdById  String?
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([accountId, status])
  @@index([assetId])
  @@map("access_blockers")
}

// â”€â”€â”€ Regulatory / Industry News â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Items pulled from public RSS feeds (OSHA news releases, electrical trade
// press) and matched against compliance-relevant terms (NFPA 70B/70E/110,
// NETA, arc flash, transformer, switchgear...). GLOBAL â€” news is industry-
// wide, not tenant data; no accountId. Populated by lib/newsScanner cron
// (6h) and the manual refresh endpoint. Feeds the /news page and the
// standard-revision awareness story (KICKOFF: no public NFPA/NETA APIs â€”
// monitor via feeds + manual workflow).

model NewsItem {
  id          String   @id @default(uuid())
  title       String
  url         String   @unique // dedup across scanner runs
  source      String // e.g. "OSHA Newsroom", "EC&M"
  category    String   @default("industry") // regulatory | standards | safety | industry
  summary     String?
  matchedTerm String? // which watch term matched, for the category chip tooltip
  publishedAt DateTime
  fetchedAt   DateTime @default(now())

  @@index([publishedAt(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
  @@map("news_items")
}

// â”€â”€â”€ Documents â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Document {
  id          String   @id @default(uuid())
  assetId     String?
  workOrderId String?
  accountId   String
  filename    String
  filePath    String // storage key (path on disk or S3 object key); '__external__' for URL-only docs
  fileType    String
  encrypted   Boolean  @default(false) // AES-256-GCM encrypted at upload time
  version     Int      @default(1)
  uploadedBy  String
  uploadedAt  DateTime @default(now())
  // Document classification â€” drives the grouped display on asset detail.
  // Null means pre-classification (legacy rows): shown under "Other".
  docType     DocType?
  // External URL: for OEM portals, shared drives, or vendor doc links where
  // uploading a copy isn't practical. When set, filePath = '__external__' and
  // the serve route redirects instead of streaming bytes.
  externalUrl String?

  asset      Asset?             @relation(fields: [assetId], references: [id])
  workOrder  WorkOrder?         @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  account    Account            @relation(fields: [accountId], references: [id])
  uploader   User               @relation("Uploader", fields: [uploadedBy], references: [id])
  ingestions IngestionSession[]

  @@index([accountId])
  @@index([assetId])
  @@index([workOrderId])
  // GET /file looks up by (filePath, accountId); without this every
  // download triggers a full table scan.
  @@index([accountId, filePath])
  @@map("documents")
}

model Communication {
  id           String            @id @default(uuid())
  assetId      String?
  contractorId String?
  accountId    String
  type         CommunicationType
  subject      String?
  body         String?
  occurredAt   DateTime
  // Nullable + ON DELETE SET NULL so the GDPR Article 17 erasure path can
  // remove a user who has authored communications; the record itself is
  // operational context the account still wants.
  createdBy    String?
  createdAt    DateTime          @default(now())

  asset         Asset?      @relation(fields: [assetId], references: [id])
  contractor    Contractor? @relation(fields: [contractorId], references: [id])
  account       Account     @relation(fields: [accountId], references: [id])
  createdByUser User?       @relation("CommunicationCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([assetId])
  @@map("communications")
}

// â”€â”€â”€ Alerts â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Lead-time tiers per the alert engine matrix:
//   180d booking window Â· 120d contractor confirm Â· 90d customer planning Â·
//   60d outage coordination Â· 30d final prep Â· 7d imminent â€” all
//   alertType=maintenance_due with leadDays set.
//   Overdue/+7d/+30d/+90d escalation rows use overdue/escalation/
//   regulatory_breach with leadDays null.

model Alert {
  id             String      @id @default(uuid())
  scheduleId     String
  assetId        String
  accountId      String
  alertType      AlertType
  leadDays       Int? // days before nextDueDate this fires (null for overdue/escalation)
  scheduledAt    DateTime
  sentAt         DateTime?
  acknowledgedAt DateTime?
  escalatedAt    DateTime?
  status         AlertStatus @default(pending)
  createdAt      DateTime    @default(now())

  schedule MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  asset    Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  account  Account             @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([assetId])
  @@index([accountId, status])
  @@index([scheduledAt, status])
  // Alert-engine dedup: filters by scheduleId IN (...) + alertType +
  // leadDays + status. Composite index keeps the dedup O(log n).
  @@index([scheduleId, alertType, leadDays, status])
  @@map("alerts")
}

model AlertPreference {
  id             String    @id @default(uuid())
  userId         String
  alertType      AlertType
  // Longer default lead list than typical renewal tooling â€” engineer
  // scheduling on outage work needs the 180/120 day horizon.
  daysBeforeList String    @default("180,120,90,60,30,7")
  emailEnabled   Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, alertType])
  @@index([userId])
  @@map("alert_preferences")
}

// â”€â”€â”€ Ingestion Sessions â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// AI-assisted extraction from uploaded PDFs (contractor test reports,
// nameplate photos, legacy maintenance logs) into structured fields.

model IngestionSession {
  id                String          @id @default(uuid())
  accountId         String
  documentId        String?
  originalFilename  String
  rawText           String?
  extractedFields   Json?
  confidenceScores  Json?
  aiNotes           Json?
  status            IngestionStatus @default(processing)
  reviewedBy        String?
  reviewCompletedAt DateTime?
  importedAt        DateTime?
  createdAt         DateTime        @default(now())

  account  Account   @relation(fields: [accountId], references: [id])
  document Document? @relation(fields: [documentId], references: [id])
  reviewer User?     @relation("IngestionReviewer", fields: [reviewedBy], references: [id])

  @@index([accountId])
  @@map("ingestion_sessions")
}

// â”€â”€â”€ Activity Log â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model ActivityLog {
  id        String   @id @default(uuid())
  assetId   String? // nullable for non-asset audit events
  userId    String? // nullable â€” login_failed for unknown emails has no associated user
  // Per-account hash chain. accountId is nullable for cross-tenant events
  // (login_failed for unknown emails); those share a single global chain
  // keyed by NULL.
  accountId String?
  action    String // condition_changed | fields_updated | work_order_completed | asset_created | login_failed | permission_denied | document_accessed | ...
  details   Json?
  createdAt DateTime @default(now())
  // Hash-chain fields. Settled by the activityLogChainSettler background job
  // ~30s after insert. rowHash = sha256(prevHash || canonical(row)).
  prevHash  String?
  rowHash   String?

  asset   Asset?   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  // SetNull cascade on userId so GDPR-erase of a User does not break the
  // transaction; historical rows remain visible with userId=null (already
  // supported by the chain verifier).
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Explicit FK on accountId so forgeable rows fail at the DB layer.
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([assetId, createdAt])
  @@index([action, createdAt])
  @@index([accountId, createdAt]) // per-account chain reads
  @@index([rowHash]) // lookup-by-hash for verifier
  @@map("activity_logs")
}

// â”€â”€â”€ Account Settings â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model AccountSetting {
  id        String   @id @default(uuid())
  accountId String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, key])
  @@index([accountId])
  @@map("account_settings")
}

// â”€â”€â”€ Early-access requests â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Landing-page lead capture via the unauthenticated POST /api/early-access
// route, rate-limited by the existing apiLimiter anonymous bucket.

model EarlyAccessRequest {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  timing    String? // 'now' | 'this_week' | 'this_month' | 'browsing' (free-form)
  ipAddress String? // spam triage only
  userAgent String? // spam triage only
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@map("early_access_requests")
}

// â”€â”€â”€ AI usage quota â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Per-user, per-action, per-day usage tracking. Composite PK enables a
// single-round-trip atomic upsert via INSERT ... ON CONFLICT DO UPDATE.
// `day` is a UTC YYYY-MM-DD string; reset on UTC midnight everywhere.

model AiUsage {
  userId String
  action String // 'ingest_extract' | 'maintenance_brief'
  day    String // 'YYYY-MM-DD' UTC
  count  Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, action, day])
  @@index([day])
  @@map("ai_usage")
}

// â”€â”€â”€ Extraction telemetry (#4) + report fingerprint / dedupe (#5) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// One row per extraction across every ingest + scan path (PDF test-report
// preview, nameplate OCR, photo inspect). Captures engine / coverage /
// confidence at extraction time and the human corrections + commit outcome at
// commit time â€” the proprietary labeled-correction dataset an acquirer
// underwrites ("12k reports, 94% field accuracy, improving monthly"). The
// sha256 + committedAt pair also powers re-import dedupe (#5): a prior commit of
// the same bytes in the same account is the "imported 2026-03-03 â€” re-import
// anyway?" signal.
//
// Deliberately FK-less (accountId/userId are plain scalars) so the migration is
// a single additive CREATE TABLE â€” telemetry is fire-and-forget and must never
// add write-path coupling or FK contention to the ingest hot path.
model ExtractionEvent {
  id              String    @id @default(uuid())
  accountId       String
  userId          String?
  kind            String // 'test_report' | 'nameplate' | 'photo_inspect'
  engine          String // source: pdfplumber | pdfplumber-ocr | pdfjs | pdfplumber+ai | ai | vision
  ocr             Boolean   @default(false)
  aiUsed          Boolean   @default(false)
  // Coverage â€” un-backfillable QA signal + honest multi-asset truncation flag.
  pageCount       Int?
  pagesScanned    Int?
  truncated       Boolean   @default(false)
  assetSections   Int?
  fieldsExtracted Int       @default(0) // readings (test_report) or nameplate fields parsed
  // Confidence distribution at extraction.
  confMin         Float?
  confMean        Float?
  redCount        Int?
  yellowCount     Int?
  greenCount      Int?
  // Fingerprint / dedupe (#5).
  sha256          String?
  // Filled at commit â€” correction capture (the labeled training signal).
  committedAt     DateTime?
  fieldsCommitted Int?
  fieldsCorrected Int?
  corrections     Json? // [{ field, before, after, formFamily }]
  reviewMs        Int?
  createdAt       DateTime  @default(now())

  @@index([accountId, createdAt])
  @@index([kind, createdAt])
  @@index([accountId, sha256]) // dedupe lookup (#5)
  @@index([accountId, committedAt]) // KPI: parsed + committed counts
  @@map("extraction_events")
}

// â”€â”€â”€ Consultant Access â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Explicit grants allowing a consultant user (Maintenance Vendor account
// manager) to access a tenant account. Not on by default â€” admin must invite
// with consultant role to create a record.

model ConsultantAccess {
  id           String    @id @default(uuid())
  accountId    String
  consultantId String // the consultant User
  grantedById  String // admin who granted access
  grantedAt    DateTime  @default(now())
  revokedById  String? // admin who revoked (null if still active)
  revokedAt    DateTime?
  isActive     Boolean   @default(true)
  notes        String? // optional context (e.g. "Q3 switchgear campaign")

  account    Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  consultant User    @relation("ConsultantUser", fields: [consultantId], references: [id])
  grantedBy  User    @relation("ConsultantGrantor", fields: [grantedById], references: [id])
  revokedBy  User?   @relation("ConsultantRevoker", fields: [revokedById], references: [id])

  @@index([accountId])
  @@index([consultantId])
  @@map("consultant_accesses")
}

// â”€â”€â”€ User Invites â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model UserInvite {
  id         String    @id @default(uuid())
  accountId  String
  email      String
  role       UserRole
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  invitedBy  String
  createdAt  DateTime  @default(now())

  account Account @relation(fields: [accountId], references: [id])
  inviter User    @relation("InviteCreator", fields: [invitedBy], references: [id])

  @@index([accountId])
  @@index([token])
  @@map("user_invites")
}

// â”€â”€â”€ Refresh Tokens â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Rotating refresh tokens (short-lived access tokens + revocable 30-day
// refresh tokens). tokenHash is SHA-256 of the opaque token value.

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  tokenHash    String // SHA-256 of the actual token (never stored plaintext)
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String? // points to the rotated successor token id
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// â”€â”€ Backup Logs â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Records each automated and manual backup attempt for audit and UI display.

model BackupLog {
  id          String   @id @default(uuid())
  accountId   String
  status      String // 'success' | 'failure'
  filename    String? // e.g. servicecycle-backup-2026-06-06T02-00-00.sql.gz
  sizeBytes   Int?
  storageKey  String? // S3 object key
  error       String? // error message if status = 'failure'
  triggeredBy String   @default("cron") // 'cron' | 'manual'
  createdAt   DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([createdAt])
  @@map("backup_logs")
}

// â”€â”€ Instance Config â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Singleton row holding deployment-wide flags that don't belong to any single
// tenant Account. Exactly one row exists, with id = 'singleton'.

model InstanceConfig {
  id               String    @id @default("singleton")
  setupCompletedAt DateTime?
  setupCompletedBy String? // userId of the admin who finished the wizard (no FK â€” survives user deletion)
  demoMode         Boolean   @default(false)
  demoLastResetAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("instance_config")
}

// --- Custom Asset Fields ------------------------------------------------------
// Admin-defined fields that show up on every asset form. The `type` column is
// text + a CHECK constraint at the DB layer so adding a new field type later
// is an ALTER (not a Postgres enum migration). Application layer enforces
// type-specific validation on write. Soft-delete (archivedAt) so existing
// asset values don't disappear when an admin retires a field.

model CustomFieldDefinition {
  id           String    @id @default(uuid())
  accountId    String
  name         String // display label
  fieldKey     String // slug, unique per account
  type         String // text | textarea | number | date | checkbox | select
  appliesTo    String? // null|asset = general; arc_flash = arc-flash equipment long tail (slice H)
  helpText     String?
  required     Boolean   @default(false)
  options      Json? // for select: [{ value, label }]
  displayOrder Int       @default(0)
  archivedAt   DateTime? // soft-delete; values stay readable
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  account   Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdBy User               @relation("CustomFieldCreator", fields: [createdById], references: [id])
  values    CustomFieldValue[]

  @@unique([accountId, fieldKey])
  @@index([accountId])
  @@index([accountId, archivedAt, displayOrder])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id           String   @id @default(uuid())
  assetId      String
  definitionId String
  // Single value column â€” text encoded; coerced to native type at the
  // application boundary on write.
  value        String?
  updatedAt    DateTime @updatedAt

  asset      Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([assetId, definitionId])
  @@index([assetId])
  @@map("custom_field_values")
}

// â”€â”€â”€ API Keys â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Per-account REST API keys for the public v1 API.
// keyHash is SHA-256 of the plaintext key â€” never stored plaintext.

model ApiKey {
  id         String    @id @default(uuid())
  accountId  String
  name       String
  keyHash    String    @unique
  // Phase 3 #7: per-key scopes. Existing keys default to read-only; a key must
  // be granted 'write' to use the bi-directional write endpoints.
  scopes     String[]  @default(["read"])
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([accountId, revokedAt])
  @@map("api_keys")
}

// Idempotency store for public-API writes (Phase 3 #7). A CMMS passes an
// Idempotency-Key header on POST; the stored response is replayed on retry so a
// re-sent request never creates a duplicate work order.
model ApiIdempotencyKey {
  id             String   @id @default(uuid())
  accountId      String
  idempotencyKey String
  method         String
  path           String
  statusCode     Int
  responseBody   Json
  createdAt      DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, idempotencyKey])
  @@index([createdAt])
  @@map("api_idempotency_keys")
}

// â”€â”€â”€ Generic Webhook Endpoints â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Per-account outbound webhook targets for maintenance-due / overdue /
// escalation alerts. Each endpoint receives a signed JSON POST whenever the
// alert engine fires.
//
// Security:
//   - `url` is stored encrypted (via lib/crypto) and validated to https:// +
//     a public IP/hostname at delivery time (SSRF guard in lib/webhook.js â€”
//     fully hardened, do not touch).
//   - `hmacSecret` is a 32-byte hex secret stored encrypted. Delivered as
//     sha256=<hex> signature header so the receiving end can verify.
//   - Maximum 5 endpoints per account enforced at the route layer.

model WebhookEndpoint {
  id         String   @id @default(uuid())
  accountId  String
  label      String   @default("")
  url        String // stored encrypted via lib/crypto
  hmacSecret String // 32-byte hex random, stored encrypted
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  account    Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dlqEntries OutboundWebhookDLQ[]

  @@index([accountId])
  @@map("webhook_endpoints")
}

// â”€â”€â”€ Outbound Webhook DLQ â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Persists a failed outbound webhook delivery after the in-process retry loop
// (3 attempts, exponential backoff) exhausts. Admin UI surfaces these for
// inspection and manual retry; the prune cron purges entries older than 30
// days so the table stays bounded.

model OutboundWebhookDLQ {
  id                String   @id @default(uuid())
  accountId         String
  webhookEndpointId String? // NULLable â€” endpoint may be deleted after a delivery fails
  deliveryId        String // per-delivery UUID echoed in the delivery-id header
  eventType         String
  targetUrlMasked   String // scheme://host/â€¦ form; full URL never persisted plaintext
  payload           Json
  attemptCount      Int      @default(0)
  lastError         String?
  lastStatus        Int?
  firstFailedAt     DateTime
  lastAttemptAt     DateTime
  createdAt         DateTime @default(now())

  account  Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  endpoint WebhookEndpoint? @relation(fields: [webhookEndpointId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([createdAt])
  @@index([deliveryId])
  @@map("outbound_webhook_dlq")
}

// â”€â”€â”€ Notification Log â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Records every alert digest send attempt (success or failure) so operators
// can answer "did asset X maintenance alert actually fire + reach the
// recipient?" without digging through application logs.
// Rows older than 180 days are pruned by the nightly prune cron.

model NotificationLog {
  id                String   @id @default(uuid())
  accountId         String
  userId            String? // recipient user (null for webhook/Slack channel sends)
  assetId           String? // asset this notification is about (null for multi-asset digests)
  channel           String // "email" | "slack" | "teams" | "webhook"
  template          String // "maintenance_due_digest" | "overdue_digest" | etc.
  recipient         String // email address, Slack channel, webhook URL (masked)
  providerMessageId String?
  status            String // "sent" | "failed" | "skipped"
  errorMessage      String? // populated when status = "failed"
  alertCount        Int? // number of alerts bundled in this digest
  sentAt            DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([accountId, sentAt(sort: Desc)])
  @@index([assetId, sentAt(sort: Desc)])
  @@index([sentAt]) // prune cron range query
  @@map("notification_logs")
}

// === RenderError ==============================================================
// Client-side render crashes captured by ErrorBoundary auto-POST to
// /api/errors/render. Anonymous (userId nullable) because demo/public pages
// can crash before auth resolves.

model RenderError {
  id             String   @id @default(uuid())
  // kind discriminator â€” 'render' (ErrorBoundary), 'uncaught'
  // (window.onerror), 'promise' (unhandledrejection), 'server' (Express
  // error middleware).
  kind           String   @default("render")
  errorCode      String // base36 timestamp from ErrorBoundary, the code shown to users
  name           String? // e.g. 'TypeError', 'ReferenceError'
  message        String? // truncated to 1000 chars server-side
  stack          String? // truncated to 4000 chars
  componentStack String? // React fiber stack
  path           String? // location.pathname at crash time (or req.path for server)
  userId         String? // null when crash predates auth
  accountId      String? // null for the same reason
  userAgent      String? // truncated to 500 chars
  appVersion     String? // from the build-id meta tag
  ip             String? // first hop only
  occurredAt     DateTime @default(now())

  @@index([occurredAt])
  @@index([errorCode])
  @@index([userId])
  @@index([kind])
  // L5 (2026-06-09 audit): admin dashboards filter server errors by tenant;
  // this composite keeps those lookups index-backed as the table grows.
  @@index([accountId, occurredAt])
  @@map("render_errors")
}

// â”€â”€â”€ Quote Requests â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Per-asset service quote requests submitted by the customer.
// The server auto-assembles a full asset dossier so the service rep gets
// everything they need without asking follow-up questions.
//
// EMERGENCY mode: when driver=down_now the frontend renders the rep phone
// number in large text with "CALL NOW".
//
// 5 standard questions (PENDING BROTHER VALIDATION â€” finalised for demo/test):
//   1. driver          â€” what prompted the request
//   2. timeline        â€” how urgently is service needed
//   3. outageAvailable â€” can the asset be de-energised + when
//   4. budgeted        â€” approved budget vs needs a number for approval
//   5. attachmentNotes â€” photos, IR scans, test reports (free text for now)
//
// Status lifecycle: requested â†’ quoted â†’ accepted | declined

model QuoteRequest {
  id              String             @id @default(uuid())
  accountId       String
  assetId         String
  requestedById   String
  status          QuoteRequestStatus @default(requested)
  // PENDING BROTHER VALIDATION â€” question values to be reviewed before
  // first real customer contact. Current values are live for demo/test.
  driver          QuoteDriver
  timeline        QuoteTimeline
  outageAvailable Boolean? // can the asset be de-energised for service?
  outageWindow    String? // when â€” free text, e.g. "Saturdays after 10pm"
  budgeted        Boolean? // has budget been approved?
  budgetNotes     String?
  attachmentNotes String? // photos, IR scans, test reports
  emergencyMode   Boolean            @default(false) // true when driver=down_now
  // System-generated trigger type â€” null when submitted manually by the customer.
  // Values: MODERNIZATION_EOL | ARC_FLASH_STUDY | QEMW_TRAINING
  triggerType     String?
  // Full asset dossier snapshot at submission time â€” nameplate, age, open
  // deficiencies, overdue tasks, downstream topology. Stored so the rep
  // always sees the state of the asset when the request was submitted.
  dossierSnapshot Json?
  notes           String? // free-text from the requester
  // DPS-derived priority: emergency | high | normal | low.
  // Auto-set at creation time from the asset's priorityScore
  // (DPS >= 20 -> emergency, 16-19 -> high, 10-15 -> normal, <10 -> low).
  priority        String?
  // Rep response fields
  quotedAt        DateTime?
  quoteNotes      String?
  respondedAt     DateTime?
  declineReason   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asset       Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requestedBy User        @relation("QuoteRequestCreator", fields: [requestedById], references: [id])
  workOrders  WorkOrder[]

  @@index([accountId])
  @@index([accountId, status])
  @@index([assetId])
  @@index([requestedById])
  @@map("quote_requests")
}

// â”€â”€â”€ LOTO â€” Lockout / Tagout Procedures â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
//
// OSHA 29 CFR 1910.147 requires a written, equipment-specific LOTO procedure
// for every piece of equipment with more than one energy source or whose
// complexity justifies a step-by-step record. This model stores the structured
// procedure directly in the app â€” energy sources and isolation steps are first-
// class rows, not a PDF upload. This enables:
//   - auditable version history (each revision creates a new LotoProc row)
//   - inline display on the asset detail page without opening a PDF
//   - inclusion in the QuoteRequest dossier ("active LOTO procedure: yes/no")
//   - future: digital sign-off / performed-by tracking on work orders
//
// A PDF backup (scanned procedure) can still be attached via Document with
// docType = loto_pdf. Both can coexist on the same asset.
//
// Lifecycle: draft â†’ active â†’ archived
//   Activating a procedure auto-archives any previously active one for this asset.

model LotoProc {
  id           String     @id @default(uuid())
  accountId    String
  assetId      String
  // Human-readable title: e.g. "480V MCC-1 Lockout Procedure Rev 3"
  title        String
  status       LotoStatus @default(draft)
  // Monotonically incrementing revision counter. Server increments on each PUT.
  version      Int        @default(1)
  // Approval fields â€” the person who reviewed and activated this revision.
  // Nullable: draft procedures don't need approval; field teams can still read them.
  approvedById String?
  approvedAt   DateTime?
  // Freeform notes: reason for revision, scope limitations, special conditions.
  notes        String?
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  account       Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asset         Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  approvedBy    User?              @relation("LotoProcApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdBy     User               @relation("LotoProcCreator", fields: [createdById], references: [id])
  energySources LotoEnergySource[]
  steps         LotoStep[]

  @@index([accountId])
  @@index([assetId])
  @@index([accountId, status])
  @@map("loto_procs")
}

// One row per energy source that must be isolated before work begins.
// Ordering controlled by sortOrder (0-based). OSHA expects all energy sources
// enumerated â€” the procedure is incomplete until every source is listed.
model LotoEnergySource {
  id                 String     @id @default(uuid())
  lotoId             String
  accountId          String
  energyType         EnergyType
  // Human description: e.g. "480V feed from MCC-1, breaker 14"
  description        String
  // Physical location of the isolation device
  isolationPoint     String
  // How to isolate: e.g. "Open breaker 14 and apply LOTO hasp + personal lock"
  isolationMethod    String
  // How to verify zero-energy state: e.g. "Test load terminals with fluke T6 â€” confirm 0V"
  verificationMethod String
  sortOrder          Int        @default(0)

  loto    LotoProc @relation(fields: [lotoId], references: [id], onDelete: Cascade)
  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([lotoId])
  @@index([accountId])
  @@map("loto_energy_sources")
}

// Ordered procedural steps: shutdown â†’ isolation â†’ lockout â†’ verify â†’ release.
// Category drives the colour-coding in the step list (red for lockout, green
// for verify, etc.) and lets auditors quickly scan the procedure structure.
model LotoStep {
  id                   String  @id @default(uuid())
  lotoId               String
  accountId            String
  sortOrder            Int
  instruction          String
  // shutdown | isolation | lockout | verify | restore | release
  // Stored as String so we can add categories without a migration.
  category             String  @default("lockout")
  // When true, the field worker must record a physical reading or tick a box
  // before proceeding. UI renders a checkbox-style row for these steps.
  requiresVerification Boolean @default(false)

  loto    LotoProc @relation(fields: [lotoId], references: [id], onDelete: Cascade)
  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([lotoId])
  @@index([accountId])
  @@map("loto_steps")
}

// â”€â”€â”€ Disaster Response â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Tracks regional weather events detected via NWS / FEMA feeds AND customer
// emergency declarations. Regional (system-detected) events have accountId=null
// and represent events that affect sites across multiple tenant accounts.
// Customer declarations have accountId set â€” the customer is asserting that
// they are in an emergency and need to jump the service queue.
//
// affectedSiteIds: for system events, all Site.ids whose state/region matches
// the NWS alert zone; for declarations, the sites selected by the customer.
// affectedStates: 2-letter state codes parsed from NWS UGC geocodes, used to
// query which accounts have sites in the impact zone without lat/lng.

model DisasterEvent {
  id              String    @id @default(cuid())
  // null  = system-detected regional event (NWS / FEMA scanner)
  // set   = customer emergency declaration (POST /api/disaster-events/declare)
  accountId       String?
  // hurricane | tornado | ice_storm | blizzard | flash_flood |
  // severe_thunderstorm | wildfire | extreme_heat | grid_failure | earthquake | manual
  eventType       String
  // watch | warning | emergency
  severity        String
  // Human-readable title â€” NWS event name or customer-provided summary.
  title           String
  // Affected region description (NWS areaDesc or free-text from customer).
  region          String
  // 2-letter state abbreviations extracted from NWS UGC codes.
  affectedStates  String[]
  // Site.id values whose state is in affectedStates (system events) or
  // sites explicitly selected by the declaring customer.
  affectedSiteIds String[]
  // NWS alert ID (@id field in NWS API response) â€” used for idempotent upsert
  // so the scanner never duplicates an in-progress alert across runs.
  nwsAlertId      String?
  // userId of the customer who clicked "Declare Emergency" â€” null for system events.
  declaredBy      String?
  // nws | fema | manual
  source          String    @default("system")
  declaredAt      DateTime  @default(now())
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  account  Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  declarer User?    @relation("DisasterDeclarer", fields: [declaredBy], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([resolvedAt])
  @@index([nwsAlertId])
  @@map("disaster_events")
}

// --- Import Webhook Delivery Log -----------------------------------------------
// Records every attempt to deliver an assets.imported webhook event so
// admins can see what fired, when, and whether it succeeded. Rows older
// than 30 days are pruned by the nightly dlq prune cron.

model WebhookDelivery {
  id         String   @id @default(uuid())
  accountId  String
  event      String // e.g. "assets.imported"
  deliveryId String // per-delivery UUID sent in X-ServiceCycle-Delivery-Id
  status     String // "delivered" | "failed"
  statusCode Int? // HTTP response code, null on network error
  responseMs Int? // round-trip milliseconds
  error      String? // error message on failure (max 1000 chars)
  payload    Json // the full payload that was sent
  createdAt  DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@map("webhook_deliveries")
}

// --- Equipment Template Library -----------------------------------------------
// Pre-built equipment profiles that pre-fill asset fields and auto-apply
// a curated task list when creating an asset from a template.
//
// Global rows (accountId = NULL) are seeded by the platform. Account-custom
// rows let facilities define their own profiles. AssetTemplateTask is the
// join table to MaintenanceTaskDefinitions auto-scheduled on asset creation.

model AssetTemplate {
  id                                   String        @id @default(uuid())
  accountId                            String? // NULL = global seed; set = account-custom
  name                                 String // "Pad-Mount Transformer 500 kVA"
  description                          String?
  equipmentType                        EquipmentType
  // Default values pre-filled on the New Asset form
  defaultCriticalityScore              Int? // 1-5
  defaultRedundancyStatus              String? // N | N_PLUS_1 | TWO_N
  defaultRequiresPredictiveMaintenance Boolean       @default(false)
  // Suggested nameplate key/value hints pre-populating the nameplate editor.
  nameplateDefaults                    Json? // { "kVA": "", "primaryVoltage": "", ... }
  createdAt                            DateTime      @default(now())
  updatedAt                            DateTime      @updatedAt

  account         Account?            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  taskDefinitions AssetTemplateTask[]

  @@index([accountId])
  @@index([equipmentType])
  @@map("asset_templates")
}

model AssetTemplateTask {
  id               String @id @default(uuid())
  templateId       String
  taskDefinitionId String

  template       AssetTemplate             @relation(fields: [templateId], references: [id], onDelete: Cascade)
  taskDefinition MaintenanceTaskDefinition @relation(fields: [taskDefinitionId], references: [id], onDelete: Cascade)

  @@unique([templateId, taskDefinitionId])
  @@map("asset_template_tasks")
}

// â”€â”€â”€ Service Rate Card (Task 24 â€” Fleet Modernization Forecast) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Platform-level and account-level pricing benchmarks used to project CapEx
// exposure on the fleet forecast. partnerOrgId=null + accountId=null = global
// default visible to all. Account-level rows override the global default for
// that account. OEMs with custom agreements can set partnerOrgId overrides.
//
// serviceType values:
//   ARC_FLASH_STUDY / SWITCHGEAR_MODERNIZATION / BREAKER_RETROFIT /
//   TRANSFORMER_REPLACEMENT / RELAY_UPGRADE / INSPECTION / LOAD_STUDY / QEMW_TRAINING
//
// Read-only aggregation only â€” no pipeline/win-loss tracking (CRM territory).
model ServiceRateCard {
  id                String   @id @default(uuid())
  partnerOrgId      String? // null = platform default
  accountId         String? // null = OEM default; account-level overrides supported
  // Phase 4 #9: enterprise-group (HoldCo) tier. A group-level card is the
  // standardized rate inherited by every OpCo in the group, sitting between the
  // account override and the partner/platform defaults in the resolver
  // (account > group > partner > platform). null on all three scopes = platform.
  enterpriseGroupId String?
  serviceType       String // see values above
  minCents          Int // minimum estimate (USD cents)
  maxCents          Int // maximum estimate (USD cents)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  enterpriseGroup EnterpriseGroup? @relation(fields: [enterpriseGroupId], references: [id], onDelete: Cascade)

  @@index([partnerOrgId])
  @@index([accountId])
  @@index([enterpriseGroupId])
  @@index([serviceType])
  @@map("service_rate_cards")
}

// --- Phase 4 #9: Enterprise group (HoldCo over OpCos) -------------------------
// A customer-side parent organization grouping multiple operating-company
// Accounts (OpCos). DISTINCT from PartnerOrganization (the OEM service channel):
// an OpCo can belong to an OEM fleet AND a HoldCo simultaneously. group_admin
// users on a member account get a cross-OpCo READ-ONLY roll-up (siblings stay
// isolated; no cross-OpCo writes). The group also owns centralized master data
// (standardized service rate cards) inherited by its OpCos via the resolver.
model EnterpriseGroup {
  id           String   @id @default(uuid())
  name         String
  logoUrl      String?
  primaryColor String? // hex, e.g. "#0a3d62"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts  Account[]
  rateCards ServiceRateCard[]

  @@map("enterprise_groups")
}

// â”€â”€â”€ Partner Invites â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Invitation tokens sent by a PartnerOrganization to link a customer Account.
// Token is stored as SHA-256 hash â€” plaintext never persisted.
// Status: PENDING â†’ ACCEPTED (acceptedAt set) | REVOKED (revokedAt set).
// Resending invalidates the prior token by overwriting tokenHash + expiresAt.

model PartnerInvite {
  id           String              @id @default(cuid())
  partnerOrgId String
  partnerOrg   PartnerOrganization @relation(fields: [partnerOrgId], references: [id])
  inviteeEmail String
  invitedById  String
  invitedBy    User                @relation("PartnerInviter", fields: [invitedById], references: [id])
  tokenHash    String              @unique // SHA-256 of the actual 32-byte hex token
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  accountId    String? // set on accept â€” FK to Account
  account      Account?            @relation(fields: [accountId], references: [id])
  createdAt    DateTime            @default(now())

  @@index([partnerOrgId])
  @@index([invitedById])
  @@index([inviteeEmail])
  @@map("partner_invites")
}

// â”€â”€â”€ Partner Event Log â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Append-only log of events fanned out from customer accounts to partner orgs.
// Archived per customer Account.retentionTier by the nightly archival cron.
// Soft-archive only: archived=true, never hard-deleted.

model PartnerEventLog {
  id                   String              @id @default(cuid())
  partnerOrgId         String
  partnerOrg           PartnerOrganization @relation(fields: [partnerOrgId], references: [id])
  accountId            String
  account              Account             @relation(fields: [accountId], references: [id])
  eventType            PartnerEventType
  payload              Json
  assignedRepId        String?
  assignedRep          User?               @relation("EventLogRep", fields: [assignedRepId], references: [id])
  digestSentAt         DateTime? // set when included in a digest email
  immediateEmailSentAt DateTime? // set for IMMEDIATE_DEFICIENCY instant email
  webhookSentAt        DateTime?
  webhookAttempts      Int                 @default(0)
  webhookLastFailedAt  DateTime?
  seenAt               DateTime?
  actionedAt           DateTime?
  archived             Boolean             @default(false)
  createdAt            DateTime            @default(now())

  @@index([partnerOrgId])
  @@index([accountId])
  @@index([partnerOrgId, archived, digestSentAt])
  @@index([accountId, eventType, createdAt])
  @@index([assignedRepId, digestSentAt])
  @@index([archived, createdAt])
  @@map("partner_event_logs")
}

// ─── Enterprise SSO + SCIM (feature/sso-polis) ────────────────────────────────
// ServiceCycle is the OAuth relying party; Ory Polis (Apache-2.0) is the broker.
// These tables map our Accounts onto Polis tenants/connections/directories and
// hold the transient CSRF/PKCE state + one-time token handoff. accountId/userId/
// connectionId are scalars here (no Prisma relations) to keep this migration
// purely additive against the large Account/User models; the hand-written
// migration adds the real FK constraints (ON DELETE CASCADE) — same pattern as
// ExtractionEvent. See docs/security/SSO_DESIGN.md.

enum SsoProtocol {
  oidc
  saml
}

// An account's SSO connection ↔ a Polis tenant/product. An account may have
// more than one (e.g. an OIDC and a SAML connection).
model SsoConnection {
  id            String      @id @default(uuid())
  accountId     String
  protocol      SsoProtocol
  // Server-derived Polis tenant id (e.g. "acct_<accountId>"). NEVER taken from
  // client input — the admin route forces it from the caller's account.
  polisTenant   String
  polisProduct  String      @default("servicecycle")
  // The connection's clientID as returned by the Polis admin API (opaque).
  polisClientId String?
  label         String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  account     Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  domains     SsoDomain[]
  loginStates SsoLoginState[]

  @@index([accountId])
  @@index([polisTenant])
  @@map("sso_connections")
}

// Email-domain → account discovery. The isolation anchor: an inbound email's
// domain resolves to exactly one account, so a user from IdP-A can only ever be
// routed into IdP-A's account. Domain is globally unique.
model SsoDomain {
  id           String   @id @default(uuid())
  domain       String   @unique // lowercased
  accountId    String
  connectionId String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account    Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  connection SsoConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([connectionId])
  @@map("sso_domains")
}

// An account's SCIM directory ↔ a Polis directory id.
model ScimDirectory {
  id               String   @id @default(uuid())
  accountId        String
  polisDirectoryId String   @unique
  polisTenant      String
  polisProduct     String   @default("servicecycle")
  type             String? // e.g. "okta-scim-v2", "azure-scim-v2"
  label            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("scim_directories")
}

// IdP group/claim → ServiceCycle role. Capped at viewer|consultant|manager at
// the app layer; admin/oem_admin/super_admin are NEVER claim-granted.
model SsoRoleMapping {
  id        String   @id @default(uuid())
  accountId String
  idpGroup  String // the group/claim value as it arrives from the IdP
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, idpGroup])
  @@index([accountId])
  @@map("sso_role_mappings")
}

// Transient per-login CSRF/PKCE state. Single-use (consumedAt) + short TTL.
// codeVerifier and nonce never leave the server.
model SsoLoginState {
  id           String    @id @default(uuid())
  state        String    @unique
  nonce        String
  codeVerifier String
  accountId    String
  connectionId String
  redirectTo   String    @default("/dashboard")
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  account    Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  connection SsoConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("sso_login_states")
}

// One-time token handoff so real JWTs never appear in a redirect URL. The SPA
// exchanges codeHash once at POST /api/sso/exchange; the JWT is minted there.
model SsoHandoff {
  id         String    @id @default(uuid())
  codeHash   String    @unique // sha256 of the one-time code
  userId     String
  accountId  String
  redirectTo String    @default("/dashboard")
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sso_handoffs")
}

// SCIM webhook idempotency/replay ledger. eventKey is sha256 of the raw event
// body; a duplicate delivery is detected and skipped. Upsert-on-externalId
// makes the underlying data write idempotent regardless.
model ScimEvent {
  id               String   @id @default(uuid())
  eventKey         String   @unique
  polisDirectoryId String?
  directoryId      String? // our ScimDirectory id when resolved
  eventType        String
  status           String   @default("processed") // processed | ignored | error
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([directoryId])
  @@map("scim_events")
}

// --- Phase 4 #8: Continuous condition-monitoring telemetry ---------------------
// Forward-looking maintenance: edge gateways / condition-monitoring platforms
// push periodic readings (winding/bushing temperature, vibration RMS, partial
// discharge, online DGA, load) into the v1 API. Each reading is graded against
// the channel's warn/crit thresholds; a CRIT breach raises a TelemetryNotification
// and escalates the asset to NFPA 70B:2023 Condition 2 until addressed. The
// 2026 OT transport standard is OPC-UA + MQTT/Sparkplug B; we ingest over an
// API-key-scoped HTTP push endpoint and document the edge-gateway bridge
// (docs/api/TELEMETRY.md) rather than running a broker in-process.

// A monitored signal on one asset (e.g. "winding_temp", "vibration_rms").
// Thresholds are optional: an auto-created channel ingests history with no
// grading (status always OK) until a threshold is set. warn/crit come in HIGH
// and LOW pairs so the same model handles "higher is worse" (temperature,
// vibration, PD) and "lower is worse" (insulation resistance, oil level).
model TelemetryChannel {
  id            String           @id @default(uuid())
  accountId     String
  assetId       String
  key           String // stable machine key, e.g. "winding_temp"
  label         String? // human label, e.g. "Winding Temperature"
  unit          String? // "C", "mm/s", "pC", "MOhm", ...
  warnHigh      Decimal?         @db.Decimal(16, 4)
  critHigh      Decimal?         @db.Decimal(16, 4)
  warnLow       Decimal?         @db.Decimal(16, 4)
  critLow       Decimal?         @db.Decimal(16, 4)
  enabled       Boolean          @default(true)
  lastValue     Decimal?         @db.Decimal(16, 4)
  lastStatus    TelemetryStatus?
  lastReadingAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  account       Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asset         Asset                   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  readings      TelemetryReading[]
  notifications TelemetryNotification[]

  @@unique([assetId, key])
  @@index([accountId])
  @@index([accountId, assetId])
  @@map("telemetry_channels")
}

// One time-series sample on a channel. recordedAt is the device timestamp;
// externalId (when supplied) dedups at-least-once gateway delivery.
model TelemetryReading {
  id         String          @id @default(uuid())
  accountId  String
  channelId  String
  assetId    String // denormalized for per-asset time-series queries
  value      Decimal         @db.Decimal(16, 4)
  unit       String?
  status     TelemetryStatus
  recordedAt DateTime // device-supplied measurement time
  source     String? // e.g. "edge-gateway-01", "opcua-bridge"
  externalId String? // gateway-side id for dedup (unique per channel)
  createdAt  DateTime        @default(now())

  account Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  channel TelemetryChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  asset   Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([channelId, externalId])
  @@index([channelId, recordedAt])
  @@index([accountId, recordedAt])
  @@index([assetId, recordedAt])
  @@map("telemetry_readings")
}

// A breach event raised on a WARN/CRIT transition. An OPEN (acknowledgedAt
// null) CRIT notification is the NFPA 70B "unaddressed notification" that holds
// the asset at Condition 2. Auto-resolved when the channel returns to OK, or
// manually acknowledged via the API.
model TelemetryNotification {
  id               String          @id @default(uuid())
  accountId        String
  assetId          String
  channelId        String
  status           TelemetryStatus // WARN | CRIT
  value            Decimal         @db.Decimal(16, 4)
  threshold        Decimal?        @db.Decimal(16, 4)
  thresholdKind    String? // "warnHigh" | "critHigh" | "warnLow" | "critLow"
  message          String
  acknowledgedAt   DateTime?
  acknowledgedById String?
  autoResolved     Boolean         @default(false) // true = cleared by a return-to-OK reading
  createdAt        DateTime        @default(now())

  account        Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asset          Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  channel        TelemetryChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  acknowledgedBy User?            @relation("TelemetryNotificationAck", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([accountId, acknowledgedAt])
  @@index([assetId, acknowledgedAt])
  @@index([channelId, acknowledgedAt])
  @@map("telemetry_notifications")
}

// â”€â”€â”€ Arc-flash Slice 2: ingest + gap-analysis â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A one-line or study-report upload, extracted by the BYO-AI cascade into a
// DRAFT system model + per-bus IEEE 1584 gap punch list. Reviewed-and-confirmed
// before anything touches real assets. Account-scoped at the app layer (scalar
// FKs, no relation objects) so this change stays purely additive to the schema.
// --- Arc-flash device taxonomy (schema-bootstrap slice 1, from ARC_FLASH_DOMAIN_MODEL.md) ---
// Trip-unit type is what determines whether recorded SETTINGS are required: only
// adjustable units (electronic LSI/LSIG, and relays) need settings; thermal-mag
// breakers, fuses, and switches derive clearing time from the published TCC.
enum TripUnitType {
  none // fuse / switch / unknown
  thermal_magnetic // fixed MCCB
  electronic_lsi // adjustable: long/short/instantaneous
  electronic_lsig // adjustable: long/short/instantaneous/ground-fault
}

// UL/CSA fuse classes (settings never apply; class + amp rating drive the TCC).
enum FuseClass {
  L
  RK1
  RK5
  J
  T
  CC
  G
  CF
  H
  K
  other
}

// Outcome / label enums (schema-bootstrap slice B).
enum PpeMethod {
  incident_energy // arc rating (ATPV/EBT) vs incident energy
  ppe_category // NFPA 70E Table 130.7(C)(15) category 1-4
}

enum LabelSeverity {
  warning
  danger // incident energy > 40 cal/cm2 OR nominal voltage > 600 V
}

// Enclosure class for the IEEE 1584-2018 size correction (slice D).
enum EnclosureType {
  panelboard
  mcc
  lv_switchgear
  mv_switchgear
  cable
  open_air
  other
}

// Per-bus calculation method (slice F).
enum CalcMethod {
  ieee_1584_2018
  lee_method // > 15 kV or outside IEEE 1584 applicability
  manufacturer_test
}

// Electrode configuration as a closed enum (slice C; promoted from String).
// IEEE 1584-2018 defines exactly these five conductor/electrode arrangements;
// the choice can change incident energy 40%+ at the same current + clearing time.
enum ElectrodeConfig {
  VCB // vertical conductors in a metal box (default enclosed case)
  VCBB // vertical conductors terminated in an insulating barrier, in a box
  HCB // horizontal conductors in a box
  VOA // vertical conductors in open air
  HOA // horizontal conductors in open air
}

model ArcFlashIngest {
  id               String    @id @default(uuid())
  accountId        String
  siteId           String
  uploadedById     String?
  sourceType       String    @default("one_line") // one_line | study_report
  fileKey          String?
  fileName         String?
  mimeType         String?
  pageCount        Int?
  extractionMethod String? // vision | text | hybrid
  aiProvider       String?
  promptVersion    String?
  status           String    @default("extracting") // extracting|extracted|needs_review|confirmed|failed
  overallBand      String? // green | yellow | red
  readyBusCount    Int       @default(0)
  totalBusCount    Int       @default(0)
  systemMeta       Json?
  rawExtraction    Json?
  error            String?
  producedStudyId  String?
  confirmedById    String?
  confirmedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  buses ArcFlashIngestBus[]

  @@index([accountId])
  @@index([accountId, siteId])
  @@index([accountId, status])
  @@map("arc_flash_ingests")
}

model ArcFlashIngestBus {
  id                   String   @id @default(uuid())
  accountId            String
  ingestId             String
  seq                  Int      @default(0)
  busName              String
  equipmentTypeGuess   String?
  fedFromBusName       String?
  nominalVoltage       String?
  boltedFaultCurrentKA Decimal? @db.Decimal(10, 2)
  arcingCurrentKA      Decimal? @db.Decimal(10, 2)
  electrodeConfig      ElectrodeConfig?
  conductorGapMm       Decimal? @db.Decimal(6, 1)
  clearingTimeMs       Decimal? @db.Decimal(10, 1)
  workingDistanceIn    Decimal? @db.Decimal(10, 1)
  upstreamDevice       String?
  // Slice 2.6 — upstream PROTECTIVE DEVICE (collected in the field down to 480V
  // panels) + FEEDER CABLE. Clearing time is DERIVED from device + settings via
  // the device's TCC curve, not a number a tech reads off the breaker.
  deviceType           String? // breaker | fuse | relay | switch
  tripUnitType         TripUnitType? // adjustable (electronic_lsi/lsig) => settings required; else not
  fuseClass            FuseClass? // when deviceType = fuse
  deviceManufacturer   String?
  deviceModel          String?
  deviceRatingA        Decimal? @db.Decimal(10, 1) // frame / sensor amp rating
  deviceSettings       Json? // LSIG trip settings (long/short/inst/gf) or fuse class+rating
  cableLengthFt        Decimal? @db.Decimal(10, 1)
  cableSize            String? // e.g. "500 kcmil", "#2 AWG"
  cableMaterial        String? // Cu | Al
  conductorsPerPhase   Int? // slice E: # conductors per phase (cable impedance)
  conduitType          String? // slice E: steel | pvc | al (conduit reactance)
  // Bootstrap slices B/D/F (mirror SystemStudyAsset so confirm carries them).
  requiredArcRatingCalCm2   Decimal?       @db.Decimal(10, 2)
  ppeMethod                 PpeMethod?
  shockLimitedApproachIn    Decimal?       @db.Decimal(10, 1)
  shockRestrictedApproachIn Decimal?       @db.Decimal(10, 1)
  labelSeverity             LabelSeverity?
  enclosureType             EnclosureType?
  enclosureHeightMm         Decimal?       @db.Decimal(8, 1)
  enclosureWidthMm          Decimal?       @db.Decimal(8, 1)
  enclosureDepthMm          Decimal?       @db.Decimal(8, 1)
  ermsPresent               Boolean?
  zsiEnabled                Boolean?
  differentialPresent       Boolean?
  arcResistant              Boolean?
  nec24087Method            String?
  calcMethod                CalcMethod?
  arcingCurrentReducedKA    Decimal?       @db.Decimal(10, 2)
  governingScenario         String?
  incidentEnergyCalCm2 Decimal? @db.Decimal(10, 2)
  arcFlashBoundaryIn   Decimal? @db.Decimal(10, 1)
  ppeCategory          Int?
  gaps                 Json?
  readiness            String   @default("blocked") // ready | defaultable | blocked
  confidence           String   @default("red") // green | yellow | red
  matchedAssetId       String?
  resolution           String   @default("pending") // pending | create | match | skip
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  ingest ArcFlashIngest @relation(fields: [ingestId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([ingestId])
  @@index([ingestId, seq])
  @@map("arc_flash_ingest_buses")
}

// --- Slice 2.7: field-collection of protective-device data + photo-read --------
// The 80% of an arc-flash study that is field-collected is the upstream
// PROTECTIVE DEVICE (frame/sensor rating + LSIG trip settings or fuse class) and
// the FEEDER CABLE, read by opening the equipment door down to 480V panels.
// ProtectiveDevice is the DURABLE record of that collected device (the ingest bus
// is a draft; this survives confirm and versions over time). Scalar FKs only so
// this stays a pure-append migration.
model ProtectiveDevice {
  id                  String    @id @default(uuid())
  accountId           String
  siteId              String
  assetId             String? // the protected/served asset (bus), once known
  ingestBusId         String? // provenance: collected against this arc-flash ingest bus
  label               String // human label, e.g. "Main CB 52-M1"
  deviceType          String? // breaker | fuse | relay | switch
  tripUnitType        TripUnitType? // adjustable (electronic_lsi/lsig) => settings required; else not
  fuseClass           FuseClass? // when deviceType = fuse
  manufacturer        String?
  model               String? // series / catalog
  partNumber          String?
  frameRatingA        Decimal? @db.Decimal(10, 1)
  sensorRatingA       Decimal? @db.Decimal(10, 1) // sensor / plug rating (drives the curve)
  settings            Json? // LSIG trip settings (long/short/inst/gf) or fuse class+rating
  settingsCollectedAt DateTime?
  collectedById       String?
  photoKey            String? // storage key of the trip-unit / nameplate photo
  source              String   @default("field") // field | photo | manual | import
  supersededById      String? // versioning: the newer record that replaces this one
  status              String   @default("active") // active | superseded
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([accountId])
  @@index([accountId, siteId])
  @@index([assetId])
  @@index([ingestBusId])
  @@index([accountId, status])
  @@map("protective_devices")
}

// A field-collection task generated from an ingest's BLOCKED buses: "open panel X
// and record the upstream device + trip settings + feeder cable". Collecting this
// data is itself an arc-flash hazard (door open / energized), so the task carries
// conservative PPE + outage + qualified-person sequencing. Distinct from
// WorkOrder, which requires an assetId and is NETA-test-shaped; these target buses
// that are not assets yet. Scalar FKs only (pure-append migration).
model ArcFlashCollectionTask {
  id                      String    @id @default(uuid())
  accountId               String
  siteId                  String
  ingestId                String?
  ingestBusId             String?
  assetId                 String?
  busName                 String
  instructions            String // what to open + record
  neededFields            Json? // the gap punch-list this task closes
  status                  String    @default("open") // open | in_progress | collected | cancelled
  assignedUserId          String? // a field_tech user
  // Safety sequencing (collection is itself an arc-flash hazard):
  hazardClass             String? // DANGER | WARNING (from the bus's current label / conservative)
  ppeNote                 String? // conservative PPE guidance for the collector
  requiresOutage          Boolean   @default(false)
  requiresQualifiedPerson Boolean   @default(true)
  collectedDeviceId       String? // -> ProtectiveDevice once collected
  collectedById           String?
  collectedAt             DateTime?
  createdById             String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([accountId])
  @@index([accountId, siteId])
  @@index([accountId, status])
  @@index([assignedUserId, status])
  @@index([ingestId])
  @@map("arc_flash_collection_tasks")
}

// ─── Slice G: NETA as-found / as-left test linkage ───────────────────────────
// Arc-flash incident energy is only valid if the protective devices actually
// trip at the settings the study assumed. A NETA relay-calibration / breaker
// trip-test record links to the device/asset/bus and captures as-found vs
// as-left settings; if they differ (or differ from the study), the study may be
// stale. Scalar FKs only (pure-append migration).
model DeviceTestRecord {
  id                 String    @id @default(uuid())
  accountId          String
  siteId             String
  assetId            String?
  protectiveDeviceId String?
  systemStudyAssetId String?
  ingestBusId        String?
  testType           String // relay_calibration | breaker_trip_test | primary_injection | as_found_as_left | other
  testDate           DateTime?
  performedBy        String?
  asFoundSettings    Json?
  asLeftSettings     Json?
  matchesStudy       Boolean? // do as-left settings match the study's assumed settings?
  driftFlagged       Boolean   @default(false) // as-found != as-left OR differs from study -> study may be stale
  result             String? // pass | fail | conditional
  notes              String?
  reportUrl          String?
  recordedById       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([accountId])
  @@index([accountId, siteId])
  @@index([assetId])
  @@index([protectiveDeviceId])
  @@index([systemStudyAssetId])
  @@map("device_test_records")
}
