{
  "name": "servicecycle-sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the ServiceCycle Public API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "private": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=20.0.0" },
  "license": "MIT",
  "keywords": ["servicecycle", "electrical", "maintenance", "nfpa70b"],
  "repository": {
    "type": "git",
    "url": "https://github.com/forgerift/servicecycle"
  },
  "homepage": "https://servicecycle.app",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
