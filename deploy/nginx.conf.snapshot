# configuration file /etc/nginx/sites-enabled/servicecycle:
server {
    listen 80;
    server_name servicecycle.app;
    location ^~ /.well-known/acme-challenge/ { allow all; root /var/www/servicecycle/html; }
    location / { return 301 https://$host$request_uri; }
}
server {
    listen 443 ssl;
    server_name servicecycle.app;
    ssl_certificate /etc/letsencrypt/live/servicecycle.app/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/servicecycle.app/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    root /var/www/servicecycle/html;
    include snippets/sc-sw-nocache.conf;
    index index.html;
    auth_basic "ServiceCycle - restricted access";
    auth_basic_user_file /etc/nginx/.htpasswd-servicecycle;
    location = /sw.js                { auth_basic off; }
    location = /manifest.webmanifest { auth_basic off; }
    location ~ ^/workbox-[^/]+\.js$  { auth_basic off; }
    location ^~ /.well-known/acme-challenge/ { auth_basic off; allow all; root /var/www/servicecycle/html; }
    location /api/ {
        auth_basic off;
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 20m;
        proxy_read_timeout 120s;
    }
    location ~* \.(?:js|css|woff2?|ttf|svg|png|jpg|jpeg|gif|ico|webp)$ {
        expires 1y; add_header Cache-Control "public, immutable"; try_files $uri =404;
    }
    location / {
        add_header Cache-Control "no-store" always;
        try_files $uri $uri/ /index.html;
    }
}
# configuration file /etc/letsencrypt/options-ssl-nginx.conf:
# This file contains important security parameters. If you modify this file
# manually, Certbot will be unable to automatically provide future security
# updates. Instead, Certbot will print and log an error message with a path to
# the up-to-date file that you will need to refer to when manually updating
# this file. Contents are based on https://ssl-config.mozilla.org
ssl_session_cache shared:le_nginx_SSL:10m;
ssl_session_timeout 1440m;
ssl_session_tickets off;
ssl_protocols TLSv1.2 TLSv1.3;
ssl_prefer_server_ciphers off;
ssl_ciphers "ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384";
# configuration file /etc/nginx/snippets/sc-sw-nocache.conf:
location ~ ^/(sw\.js|registerSW\.js|manifest\.webmanifest|sw-build-version\.json)$ {
    add_header Cache-Control "no-cache";
}
# configuration file /etc/nginx/sites-enabled/vps-mcp:
server {
    server_name 198-211-99-45.sslip.io;
    location / {
        proxy_pass         http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_cache_bypass $http_upgrade;
        # SSE requires these — do not buffer
        proxy_buffering    off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        chunked_transfer_encoding on;
    }
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/198-211-99-45.sslip.io/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/198-211-99-45.sslip.io/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}
server {
    if ($host = 198-211-99-45.sslip.io) {
        return 301 https://$host$request_uri;
    } # managed by Certbot
    listen 80;
    server_name 198-211-99-45.sslip.io;
    return 404; # managed by Certbot
}
