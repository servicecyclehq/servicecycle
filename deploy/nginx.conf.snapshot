# deploy/nginx.conf.snapshot
#
# Captured: 2026-07-08, via `ssh servicecycle-droplet "sudo nginx -T"` run
# directly by Dustin (the vps-control MCP cannot read /etc/nginx — see
# deploy/README.md for why). Raw, unedited `nginx -T` output — nothing
# redacted, because `-T` only dumps parsed config directives (paths to
# certs/htpasswd), never the referenced secret files' actual contents.
#
# Refresh this file the same way whenever the live config changes:
#   ssh servicecycle-droplet "sudo nginx -T"
# and paste the new output in, updating this header's date.
#
# ── What's in here ──────────────────────────────────────────────────────────
# Two independent vhosts on this droplet, both Certbot-managed (Let's Encrypt):
#   1. servicecycle.app         — the actual app. Basic-auth gated (see
#      sites-enabled/servicecycle below) except for a small set of PWA
#      service-worker paths that must stay reachable unauthenticated so the
#      SW can install/update; proxies /api/ to 127.0.0.1:3002 (this droplet's
#      SERVER_PORT override — see docker-compose.yml's default of 3001);
#      serves static files straight from /var/www/servicecycle/html (the
#      deploy_client MCP tool's fixed publish target).
#   2. 198-211-99-45.sslip.io   — UNRELATED to ServiceCycle: this is the
#      vps-control MCP server's own HTTPS endpoint (SSE, chunked transfer,
#      proxies to 127.0.0.1:3001). Sharing this droplet's nginx + Certbot,
#      not part of the app.
#
# Basic-auth file: /etc/nginx/.htpasswd-servicecycle (path only — contents
# never pulled, per the redaction policy above).
#
# ── Raw `nginx -T` output ────────────────────────────────────────────────────

nginx: the configuration file /etc/nginx/nginx.conf syntax is ok
# configuration file /etc/nginx/nginx.conf:
user www-data;
worker_processes auto;
pid /run/nginx.pid;
error_log /var/log/nginx/error.log;
include /etc/nginx/modules-enabled/*.conf;
events {
        worker_connections 768;
        # multi_accept on;
}
http {
        ##
        # Basic Settings
        ##
        sendfile on;
        tcp_nopush on;
        types_hash_max_size 2048;
        # server_tokens off;
        # server_names_hash_bucket_size 64;
        # server_name_in_redirect off;
        include /etc/nginx/mime.types;
        default_type application/octet-stream;
        ##
        # SSL Settings
        ##
        ssl_protocols TLSv1 TLSv1.1 TLSv1.2 TLSv1.3; # Dropping SSLv3, ref: POODLE
        ssl_prefer_server_ciphers on;
        ##
        # Logging Settings
        ##
        access_log /var/log/nginx/access.log;
        ##
        # Gzip Settings
        ##
        gzip on;
        # gzip_vary on;
        # gzip_proxied any;
        # gzip_comp_level 6;
        # gzip_buffers 16 8k;
        # gzip_http_version 1.1;
        # gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;
        ##
        # Virtual Host Configs
        ##
        include /etc/nginx/conf.d/*.conf;
        include /etc/nginx/sites-enabled/*;
}
